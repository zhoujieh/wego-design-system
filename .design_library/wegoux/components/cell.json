  "structurePatterns": [
    "左侧插槽默认保持单一前导语义；编辑态允许退格占位、选择控件和头像做紧凑组合。",
    "前导槽位组与正文内容之间默认保持 12px 间距，避免 checkbox、radio、图标或头像贴近标题。",
    "中间内容区固定标题优先、副标题次级，不扩成多列表格。",
    "右侧操作区最多承担一种主反馈类型，例如文字、角标、按钮、开关或箭头。",
    "自定义链接类操作沿用 .cell__action 宿主，本体不额外补右侧间距，保证内容距屏幕右侧保持 16px。"
  ],
  "behavior": {
    "click": "clickable 时整行响应按压态，局部操作仍保持清晰热区。",
    "divider": "分割线样式由修饰类控制，但左侧起点始终跟随正文文本左边缘对齐，不因前导插槽场景漂移。",
    "slots": "右侧角标和箭头属于 trailing slot，不在标题区新增重复操作。"
  },
  "accessibility": {
    "rowRole": "点击整行时需提供一致的可聚焦或可点击语义。",
    "textOverflow": "标题与副标题允许省略，避免压缩右侧操作区。",
    "nestedControl": "嵌套 checkbox 或 radio 时不要让整行点击与控件状态冲突。"
  },
  "usageHints": [
    "适合设置页、资料页、订单信息摘要等移动端高密度列表。",
    "双行模式用于副标题需要解释信息时，避免在单行强塞长文案。",
    "右侧是链接、按钮或开关时，仍应保持单一主反馈，不在同一行叠加多种主操作。"
  ],
  "doNotInvent": [
    "不要把 cell 扩成桌面表格行、树形列表或多列数据面板。",
    "不要在 cell 内同时放多个同级主操作按钮。"
  ],
