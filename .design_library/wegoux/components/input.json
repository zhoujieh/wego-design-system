  "structurePatterns": [
    "标签始终置于输入区上方，组内使用固定纵向间距。",
    "text 和 textarea 共享边框与状态体系，不分裂成不同组件。",
    "错误和禁用通过根节点状态类驱动。",
    "标准文本输入框（input[type=text]）支持清除按钮，通过 .input-wrapper 包裹 input 和 .input-clear 实现。",
    "清除按钮仅标准文本输入框显示，数字输入框和多行文本输入框不显示清除按钮。",
    "禁用态不显示清除按钮，错误态清除图标变为红色。"
  ],
  "behavior": {
    "focus": "聚焦时边框切到品牌色。",
    "error": "错误态同时作用于边框、输入文字和清除图标颜色，并在输入框下方显示错误提示文本。",
    "disabled": "禁用态弱化标签与输入区，阻止交互，隐藏清除按钮。",
    "clear": "标准文本输入框有内容时显示清除按钮（icon-yuancha-mian，16px，默认占位文字色），点击后清空内容并聚焦。数字输入框和 textarea 不显示清除按钮。"
  },
  "accessibility": {
    "labelAssociation": "标签需通过 for/id 或包裹关系关联具体输入控件。",
    "errorFeedback": "错误信息应与字段关联，避免只靠颜色表达。",
    "keyboard": "textarea 保留原生输入与换行行为。"
  },
  "usageHints": [
    "适合单字段独立陈列，不替代表单容器型 form。",
    "需要多字段对齐、上传、选择等复合场景时优先使用 form。"
