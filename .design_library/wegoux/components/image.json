{
  "slug": "image",
  "name": "图片",
  "sourceKind": "inferred",
  "confidence": "high",
  "description": "图片组件（WGImage），用于展示图片内容。支持 xs/sm/md/lg/xl 五种预设尺寸 + 自定义矩形/宽幅尺寸，cover/contain 两种填充模式，rounded-sm/rounded-md/rounded-lg/circle 四种圆角变体，loading/loaded/error 三种加载状态，clickable 叠加层交互。",
  "variants": [
    {
      "name": "覆盖模式 (Cover)",
      "type": "cover",
      "description": "默认模式，object-fit: cover，图片裁剪填充"
    },
    {
      "name": "包含模式 (Contain)",
      "type": "contain",
      "description": "object-fit: contain，图片完整显示不裁剪"
    }
  ],
  "presetSizes": [
    { "name": "极小", "slug": "xs", "width": "16px", "height": "16px" },
    { "name": "小", "slug": "sm", "width": "32px", "height": "32px" },
    { "name": "中", "slug": "md", "width": "64px", "height": "64px" },
    { "name": "大", "slug": "lg", "width": "104px", "height": "104px" },
    { "name": "超大", "slug": "xl", "width": "72px", "height": "72px" }
  ],
  "customSizes": [
    { "name": "矩形", "slug": "custom-rect", "width": "180px", "height": "120px" },
    { "name": "宽幅", "slug": "custom-wide", "width": "260px", "height": "160px" }
  ],
  "roundedVariants": [
    { "name": "小圆角", "slug": "rounded-sm", "borderRadius": "var(--wg-radius-sm)" },
    { "name": "中圆角", "slug": "rounded-md", "borderRadius": "var(--wg-radius-md)" },
    { "name": "大圆角", "slug": "rounded-lg", "borderRadius": "var(--wg-radius-lg)" },
    { "name": "圆形", "slug": "circle", "borderRadius": "var(--wg-radius-full)" }
  ],
  "states": [
    {
      "name": "加载中 (Loading)",
      "type": "loading",
      "className": "wg-image--loading",
      "description": "图片加载中，背景为 --wg-color-base-neutral-100，图片 opacity 0"
    },
    {
      "name": "已加载 (Loaded)",
      "type": "loaded",
      "className": "is-loaded",
      "description": "图片加载完成，opacity 1，过渡动画透明"
    },
    {
      "name": "加载失败 (Error)",
      "type": "error",
      "className": "wg-image--error",
      "description": "图片加载失败，显示占位符（24x24px 空心矩形框），图片隐藏"
    }
  ],
  "modifiers": [
    {
      "name": "可点击",
      "slug": "clickable",
      "description": "cursor pointer，点击时显示半透明深色叠加层（rgba 30% neutral）"
    },
    {
      "name": "透明背景",
      "slug": "transparent",
      "description": "图片背景设为透明（默认有 --wg-color-base-neutral-100 背景）"
    }
  ],
  "designTokens": {
    "defaultBackground": "var(--wg-color-base-neutral-100)",
    "defaultFit": "cover",
    "loadingBackground": "var(--wg-color-base-neutral-100)",
    "errorPlaceholderSize": "24px",
    "errorPlaceholderBorder": "2px solid var(--wg-color-text-disabled)",
    "overlayBackground": "var(--wg-color-base-neutral-alpha-30)",
    "transitionDuration": "var(--wg-motion-duration-normal)",
    "transitionEasing": "var(--wg-motion-ease-standard)",
    "fontFamily": "PingFang SC",
    "placeholderFontSize": "10px",
    "placeholderFontWeight": 400,
    "placeholderColor": "var(--wg-color-text-disabled)"
  },
  "unknowns": []
}
