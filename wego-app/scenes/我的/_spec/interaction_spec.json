    {
      "node_id": "view-profile",
      "purpose": "查看店主身份信息（头像、名称、SVIP 徽标、角色）与身份操作入口（+员工、员工管理）",
      "surface_ref": "my-home-main",
      "inputs": ["店主身份数据"],
      "outputs": [],
      "key_states": ["默认", "操作反馈"]
