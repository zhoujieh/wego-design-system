  "assumptions": [
    {
      "assumption": "「我的」Tab 作为宿主固定 Tab，参照动态 Tab 处理方式：通过底部导航切换进入，不注册 hash push 路由；prototype_target.routes 留空数组，surface 用 carrier:host-fixed-tab 表达，host_container.tab=my 标识归属。运行时 Tab 切换仍由 app.js setActiveTab 处理，内容继续由 index.html + app.css 承载，不迁移到 scene.js 结构",
      "impact_level": "low",
      "reversible": true
    },
    {
      "assumption": "本次优化聚焦按新工作流补齐规格文档并梳理宿主页信息块结构，业务内容不变（身份、会员、应用中心、设置四块结构保持），具体视觉与组件决策由 design_plan 承载",
      "impact_level": "low",
      "reversible": true
    },
    {
      "assumption": "未实现入口（一键开团、店铺装修、收款码、我的小店、空间管理）及身份/会员操作按钮（+员工、员工管理、去续费）本次标 stub，点击后 toast 反馈，不实现下钻流程",
      "impact_level": "low",
      "reversible": true
    }
  ],
