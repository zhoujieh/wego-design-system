      "inputs": ["会员与用量数据"],
      "outputs": [],
      "key_states": ["默认", "操作反馈"]
    },
    {
      "node_id": "view-app-center",
      "purpose": "浏览应用中心 Grid 入口集合（一键开团、店铺装修、收款码、我的小店、价格管理、库存管理、仓库管理）",
