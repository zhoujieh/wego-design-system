{
  "task_type": "design-system-consumption",
  "scene_category": "other",
  "goal": "让店主在「我的」Tab 查看店铺身份与会员权益，并触达店铺管理、应用工具与系统设置等业务入口",
  "scope": {
    "included": [
      "店主身份卡片：头像、店主名称、SVIP 徽标、角色、+员工与员工管理入口",
      "SVIP 会员卡：会员标签、去续费入口、存储用量、空间管理入口",
      "应用中心 Grid：一键开团、店铺装修、收款码、我的小店、价格管理、库存管理、仓库管理",
      "设置列表：系统设置入口"
    ],
    "excluded": [
      "各入口下钻的业务场景（价格管理、库存管理、仓库管理、系统设置等已有独立场景）",
      "+员工、员工管理、去续费、空间管理等下钻流程（本次不实现）",
      "底部 Tab 切换逻辑（由 app.js 统一承载，不在本规格范围）"
    ]
  },
  "actors": [
    { "id": "shop-owner", "role": "店主", "purpose": "查看自身身份、会员权益与存储用量，并下钻到店铺管理、应用工具与系统设置入口" }
  ],
  "entry_points": [
    {
      "id": "my-tab",
      "carrier": "host-fixed-tab",
      "description": "宿主底部第五个固定 Tab，点击切换到「我的」宿主页"
    }
  ],
  "flows": [
    {
      "flow_id": "browse-my-home",
      "flow_type": "main",
      "entry_node": "enter-my",
      "steps": ["enter-my", "view-profile", "view-membership", "view-app-center", "view-settings", "navigate-entry"],
      "exit_condition": "切换到其他 Tab 或下钻到业务入口"
    }
  ],
  "flow_nodes": [
    {
      "node_id": "enter-my",
      "purpose": "进入「我的」Tab，展示店主身份、会员、应用中心与设置入口",
      "surface_ref": "my-home-main",
      "inputs": [],
      "outputs": ["宿主页静态内容"],
      "key_states": ["默认展示态"]
