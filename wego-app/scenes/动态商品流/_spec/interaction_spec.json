      "interaction": "浏览图片",
      "default_state": "显示",
      "editable": false,
      "key_states": [
        "单图态",
        "双图态",
        "多图态"
      ]
    },
    {
      "content_id": "post-product",
      "group": "post-card",
      "content": "商品标题、价格、划线价、标签、规格摘要和库存提示",
      "interaction": "点击进入详情",
      "default_state": "显示",
      "editable": false,
      "key_states": [
        "长商品信息态"
      ]
    },
    {
      "content_id": "post-actions",
      "group": "post-card",
      "content": "看详情、询价和更多操作",
      "interaction": "轻操作",
      "default_state": "显示",
      "editable": false,
      "key_states": [
        "默认浏览态"
      ]
    },
    {
      "content_id": "detail-gallery",
      "group": "detail-page",
      "content": "商品详情主图和缩略图切换",
      "interaction": "切换图片",
      "default_state": "显示",
      "editable": false,
      "key_states": [
        "商品图切换态"
      ]
    },
    {
      "content_id": "detail-product",
      "group": "detail-page",
      "content": "完整商品信息、价格、规格、配送和服务承诺",
      "interaction": "浏览",
      "default_state": "显示",
      "editable": false,
      "key_states": [
        "详情浏览态"
      ]
    },
    {
      "content_id": "detail-dynamic-note",
      "group": "detail-page",
      "content": "对应动态正文；当正文为空时改为“仅发布商品”状态说明",
      "interaction": "浏览",
      "default_state": "显示",
      "editable": false,
      "key_states": [
        "无正文补充态"
      ]
    },
    {
      "content_id": "detail-actions",
      "group": "detail-page",
      "content": "联系店主和立即下单的详情页动作收口",
      "interaction": "页面级动作",
      "default_state": "显示",
      "editable": false,
      "key_states": [
        "详情浏览态"
      ]
    },
    {
      "content_id": "sheet-actions",
      "group": "sheet",
      "content": "查看详情、转发给客户、收藏商品、联系店主",
      "interaction": "单步操作",
      "default_state": "显示",
      "editable": false,
      "key_states": [
        "操作收口态"
      ]
    }
  ],
  "states": [
    {
      "state_id": "edge-cases",
      "description": "正文为空时直接让媒体或商品摘要顶上；多图时按数量自动切换 1 图、2 图和多图布局；长商品信息允许两行标题和多行辅助信息，不压缩成单行省略。"
    }
  ],
  "transitions": [
    {
      "transition_id": "go-detail-from-post",
      "from": "scan-feed",
      "trigger": "点击商品摘要或看详情",
      "to": "open-detail",
      "data_in": [
        "selected-post-id"
      ],
      "result_out": [
        "detail-post"
      ]
    },
    {
      "transition_id": "open-sheet-from-post",
      "from": "scan-feed",
      "trigger": "点击更多",
      "to": "open-more-actions",
      "data_in": [
        "selected-post-id"
      ],
      "result_out": []
    },
    {
      "transition_id": "finish-sheet-action",
      "from": "open-more-actions",
      "trigger": "点击某个轻操作",
      "to": "execute-light-action",
      "data_in": [
        "action-type",
        "selected-post-id"
      ],
      "result_out": [
        "action-feedback"
      ],
      "return_to": "scan-feed",
      "return_payload": [
        "action-feedback"
      ]
    }
  ],
  "data_handoffs": [
    {
      "handoff_id": "selected-post-to-detail",
      "transition_id": "go-detail-from-post",
      "source_node": "scan-feed",
      "target_node": "open-detail",
      "payload_content_refs": [
        "post-product",
        "post-media",
        "post-text"
      ],
      "reset_policy": "keep"
    },
    {
      "handoff_id": "sheet-action-feedback",
      "transition_id": "finish-sheet-action",
      "source_node": "open-more-actions",
      "target_node": "execute-light-action",
      "payload_content_refs": [
        "sheet-actions"
      ],
      "reset_policy": "clear-on-success"
    }
  ],
  "exit_results": [
    {
      "result_id": "stay-in-feed",
      "description": "用户继续浏览动态流"
    },
    {
      "result_id": "enter-product-detail",
      "description": "用户进入商品详情"
    },
    {
      "result_id": "finish-light-action",
      "description": "用户完成轻操作并收到 toast 反馈"
    }
