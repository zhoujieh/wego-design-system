{
  "iteration_context": {
    "iteration_id": "album001",
    "scope_revision": 1,
    "requirement_ids": [
      "album001-R01",
      "album001-R02",
      "album001-R03",
      "album001-R04"
    ]
  },
  "goal": "让用户在动态 Tab 中连续浏览店主发布的商品动态，并能稳定查看商品摘要、进入详情或执行轻操作。",
  "scope": {
    "included": [
      "动态流浏览",
      "详情下钻",
      "轻操作与更多操作收口"
    ],
    "excluded": [
      "真实下单",
      "评论与点赞",
      "服务端刷新与分页"
    ]
  },
  "actors": [
    {
      "actor_id": "shop-visitor",
      "role": "逛店用户",
      "goal": "快速判断动态里的商品是否值得点进详情或继续操作"
    }
  ],
  "entry_points": [
    {
      "entry_id": "tab-dongtai",
      "label": "底部 Tab「动态」",
      "surface_ref": "feed-surface"
    }
  ],
  "flows": [
    {
      "flow_id": "feed-browse-flow",
      "flow_type": "main",
      "entry_node": "enter-feed",
      "steps": [
        "enter-feed",
        "scan-feed",
        "compare-posts"
      ],
      "exit_condition": "用户继续停留在动态流中浏览下一条内容"
    },
    {
      "flow_id": "detail-drill-flow",
      "flow_type": "branch",
      "entry_node": "scan-feed",
      "steps": [
        "scan-feed",
        "open-detail",
        "view-detail"
      ],
      "exit_condition": "用户完成商品详情浏览并可返回动态流"
    },
    {
      "flow_id": "action-sheet-flow",
      "flow_type": "branch",
      "entry_node": "scan-feed",
      "steps": [
        "scan-feed",
        "open-more-actions",
        "execute-light-action"
      ],
      "exit_condition": "用户完成轻操作并回到原动态流位置"
    }
  ],
  "flow_nodes": [
    {
      "node_id": "enter-feed",
      "purpose": "进入动态 Tab 宿主页并看到连续内容流首屏",
      "surface_ref": "feed-surface",
      "inputs": [],
      "outputs": [],
      "key_states": [
        "默认浏览态"
      ]
    },
    {
      "node_id": "scan-feed",
      "purpose": "纵向浏览多条动态并识别发布者、时间、正文、图片和商品摘要",
      "surface_ref": "feed-surface",
      "inputs": [
        "feed-posts"
      ],
      "outputs": [
        "selected-post-id"
      ],
      "key_states": [
        "多图态",
        "无正文态",
        "长商品信息态"
      ]
    },
    {
      "node_id": "compare-posts",
      "purpose": "在不跳页的情况下快速比较多条动态中的商品信息和发布节奏",
      "surface_ref": "feed-surface",
      "inputs": [
        "feed-posts"
      ],
      "outputs": [],
      "key_states": [
        "连续浏览态"
      ]
    },
    {
      "node_id": "open-detail",
      "purpose": "点击商品摘要或详情入口，带着选中动态进入商品详情页",
      "surface_ref": "detail-surface",
      "inputs": [
        "selected-post-id"
      ],
      "outputs": [
        "detail-post"
      ],
      "key_states": [
        "详情打开态"
      ]
    },
    {
      "node_id": "view-detail",
      "purpose": "查看完整商品图片、价格、规格和动态说明，并执行联系店主或下单等后续动作",
      "surface_ref": "detail-surface",
      "inputs": [
        "detail-post"
      ],
      "outputs": [],
      "key_states": [
        "详情浏览态",
        "商品图切换态"
      ]
    },
    {
      "node_id": "open-more-actions",
      "purpose": "打开更多操作 sheet，查看转发、收藏、联系店主等操作入口",
      "surface_ref": "action-sheet-surface",
      "inputs": [
        "selected-post-id"
      ],
      "outputs": [],
      "key_states": [
        "操作收口态"
      ]
    },
    {
      "node_id": "execute-light-action",
      "purpose": "执行询价、转发或收藏等轻操作并回到原浏览位置",
      "surface_ref": "action-sheet-surface",
      "inputs": [
        "selected-post-id",
        "action-type"
      ],
      "outputs": [
        "action-feedback"
      ],
      "key_states": [
        "操作完成态"
      ]
    }
  ],
  "surfaces": [
    {
      "surface_id": "feed-surface",
      "role": "primary-task-page",
      "carrier": "host-section",
      "node_refs": [
        "enter-feed",
        "scan-feed",
        "compare-posts"
      ],
      "content_refs": [
        "post-identity",
        "post-text",
        "post-media",
        "post-product",
        "post-actions"
      ],
      "interaction_mode": "continuous-browse",
      "purpose": "动态 Tab 宿主页中的连续商品流，服务连续扫读和轻量判断",
      "states": [
        "默认浏览态",
        "无正文态",
        "单图态",
        "双图态",
        "多图态",
        "长商品信息态"
      ]
    },
    {
      "surface_id": "detail-surface",
      "role": "secondary-task-page",
      "carrier": "standalone-page",
      "node_refs": [
        "open-detail",
        "view-detail"
      ],
      "content_refs": [
        "detail-gallery",
        "detail-product",
        "detail-dynamic-note",
        "detail-actions"
      ],
      "interaction_mode": "browse-then-act",
      "purpose": "商品详情承接完整商品信息、图片浏览和后续动作",
      "states": [
        "详情浏览态",
        "商品图切换态",
        "无正文补充态"
      ]
    },
    {
      "surface_id": "action-sheet-surface",
      "role": "secondary-task-page",
      "carrier": "sheet",
      "node_refs": [
        "open-more-actions",
        "execute-light-action"
      ],
      "content_refs": [
        "sheet-actions"
      ],
      "interaction_mode": "single-step-action",
      "purpose": "收纳多余轻操作，避免在列表项中堆叠过多入口",
      "states": [
        "操作收口态",
        "操作完成态"
      ]
    }
  ],
  "content_blocks": [
    {
      "content_id": "feed-summary",
      "group": "feed-header",
      "content": "动态总数、今日更新数、在售商品数",
      "interaction": "只读摘要",
      "default_state": "显示",
      "editable": false,
      "key_states": [
        "默认浏览态"
      ]
    },
    {
      "content_id": "post-identity",
      "group": "post-card",
      "content": "发布者头像、名称、身份标签、发布时间",
      "interaction": "轻识别",
      "default_state": "显示",
      "editable": false,
      "key_states": [
        "默认浏览态"
      ]
    },
    {
      "content_id": "post-text",
      "group": "post-card",
      "content": "动态正文，可为空",
      "interaction": "浏览",
      "default_state": "按数据有无决定显示",
      "editable": false,
      "key_states": [
        "无正文态"
      ]
    },
    {
      "content_id": "post-media",
