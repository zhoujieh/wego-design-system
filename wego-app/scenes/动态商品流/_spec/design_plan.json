  "page_strategy": {
    "page_goal": "让用户在连续滑动中稳定识别每条商品动态的核心信息，并快速做下钻决策。",
    "page_pattern": "content-feed",
    "layout_pattern": "single-column-card-flow",
    "main_scroll_direction": "vertical",
    "content_density": "medium",
    "fixed_vs_scroll": "顶部导航固定，内容区纵向滚动，详情底部动作固定",
    "first_screen_goal": "首屏同时出现页面标题、浏览说明、筛选标签与至少一条完整动态卡片",
    "region_priority": [
      "动态卡片列表",
      "卡片内商品信息",
      "轻量筛选和说明"
    ],
    "scroll_rhythm": "以 12px 卡片间距形成稳定节奏，保证文案长短和图片数量变化时仍连续可扫读",
    "visual_competition": "图片、商品卡和动作区按先内容后动作层级递减，避免按钮抢占信息判断"
  },
