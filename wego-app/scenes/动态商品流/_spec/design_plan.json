  "page_strategy": {
    "page_goal": "让用户在一个稳定节奏里连续扫读商品动态，并在需要时顺畅下钻到详情。",
    "page_pattern": "",
    "layout_pattern": "sticky-navbar + summary + feed-list / push-detail + sticky-action-bar",
    "main_scroll_direction": "vertical",
    "content_density": "high",
    "fixed_vs_scroll": "navbar 固定，摘要与内容流滚动；详情页底部动作固定，正文滚动。",
    "first_screen_goal": "首屏同时给出动态总览和至少一条完整商品动态，帮助用户立即开始比较。",
    "region_priority": [
      "动态识别信息",
      "商品摘要",
      "正文与媒体",
      "轻操作"
    ],
    "scroll_rhythm": "按动态卡片连续纵向堆叠，卡片之间保持 8px 节奏，减少视觉割裂。",
    "visual_competition": "商品摘要与识别信息优先于媒体面积，媒体只做辅助判断。"
  },
