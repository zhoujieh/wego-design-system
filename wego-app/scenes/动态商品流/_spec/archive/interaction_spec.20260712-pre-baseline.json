{
  "iteration_context": {
    "iteration_id": "feed001",
    "scope_revision": 1,
    "requirement_ids": [
      "feed001-R01",
      "feed001-R02",
      "feed001-R03",
      "feed001-R04"
    ]
  },
  "goal": "为微购相册提供一个可连续浏览的动态商品流，让用户稳定查看店主发布的商品动态，并能快速进入商品详情或执行关键动作。",
  "scope": {
    "in_scope": [
      "按时间倒序浏览商品动态",
      "展示发布者、发布时间、文案、图片和商品信息",
      "从动态进入商品详情",
      "保留筛选、分享、加入选货单等关键动作入口"
    ],
    "out_of_scope": [
      "真实聊天和下单接口",
      "动态发布与编辑后台",
      "图片全屏缩放浏览"
    ]
  },
  "actors": [
    {
      "actor_id": "shop-buyer",
      "name": "选货用户",
      "goal": "高频浏览店主动态并快速判断商品是否值得继续查看"
    }
  ],
  "entry_points": [
    {
      "entry_id": "entry-dongtai-tab",
      "surface_ref": "surface-feed",
      "trigger": "底部 Tab 打开动态页"
    }
  ],
  "flows": [
    {
      "flow_id": "flow-feed-browse",
      "flow_type": "main",
      "entry_node": "node-feed-list",
      "steps": [
        "node-feed-list",
        "node-product-detail"
      ],
      "exit_condition": "用户完成连续浏览，或进入商品详情执行下一步动作"
    },
    {
      "flow_id": "flow-feed-actions",
      "flow_type": "branch",
      "entry_node": "node-feed-list",
      "steps": [
        "node-feed-list",
        "node-action-sheet"
      ],
      "exit_condition": "用户查看筛选或更多操作后返回原列表"
    }
  ],
  "flow_nodes": [
    {
      "node_id": "node-feed-list",
      "purpose": "承载连续浏览的商品动态列表",
      "surface_ref": "surface-feed",
      "inputs": [
        "动态流数据"
      ],
      "outputs": [
        "当前选中的商品"
      ],
      "key_states": [
        "文案为空",
        "图片数量 1/3/4",
        "商品信息较长"
      ]
    },
    {
      "node_id": "node-product-detail",
      "purpose": "查看单个商品的扩展信息并执行关键动作",
      "surface_ref": "surface-detail",
      "inputs": [
        "当前选中的商品"
      ],
      "outputs": [
        "加入选货单反馈",
        "联系店主反馈"
      ],
      "key_states": [
        "返回列表",
        "发起关键动作"
      ]
    },
    {
      "node_id": "node-action-sheet",
      "purpose": "承载轻量筛选或更多操作",
      "surface_ref": "surface-action-sheet",
      "inputs": [
        "当前页面上下文"
      ],
      "outputs": [
        "操作反馈"
      ],
      "key_states": [
        "打开",
        "关闭"
      ]
    }
  ],
  "surfaces": [
    {
      "surface_id": "surface-feed",
      "role": "primary-task-page",
      "carrier": "host-section",
      "node_refs": [
        "node-feed-list"
      ],
      "content_refs": [
        "content-feed-header",
        "content-feed-cards",
        "content-feed-actions"
      ],
      "interaction_mode": "browse-and-drilldown",
      "purpose": "连续浏览动态商品流",
      "states": [
        "default"
      ]
    },
    {
      "surface_id": "surface-detail",
      "role": "secondary-task-page",
      "carrier": "standalone-page",
      "node_refs": [
        "node-product-detail"
      ],
      "content_refs": [
        "content-detail-hero",
        "content-detail-summary",
        "content-detail-origin"
      ],
      "interaction_mode": "inspect-and-act",
      "purpose": "查看商品详情并执行必要操作",
      "states": [
        "default"
      ]
    },
    {
      "surface_id": "surface-action-sheet",
      "role": "result-summary",
      "carrier": "sheet",
      "node_refs": [
        "node-action-sheet"
      ],
      "content_refs": [
        "content-sheet-actions"
      ],
      "interaction_mode": "lightweight-selection",
      "purpose": "提供筛选和更多操作入口",
      "states": [
        "open",
        "closed"
      ]
    }
  ],
  "content_blocks": [
    {
      "content_id": "content-feed-header",
      "content": "动态页标题、导览说明与筛选标签",
      "group": "feed-header",
      "interaction": "筛选入口保留为可点击反馈",
      "default_state": "visible",
      "editable": false,
      "key_states": [
        "default"
      ]
    },
    {
      "content_id": "content-feed-cards",
      "content": "按时间倒序排列的动态卡片，每张卡片包含发布者、时间、文字、图片与商品卡",
      "group": "feed-list",
      "interaction": "点击商品卡或主按钮进入详情",
      "default_state": "visible",
      "editable": false,
      "key_states": [
        "无文案",
        "多图",
        "长商品信息"
      ]
    },
    {
      "content_id": "content-feed-actions",
      "content": "转发动态、加入选货单、查看商品等动作",
      "group": "feed-actions",
      "interaction": "点击后提供反馈或跳转",
      "default_state": "visible",
      "editable": false,
      "key_states": [
        "反馈提示"
      ]
    },
    {
      "content_id": "content-detail-hero",
      "content": "详情页首图",
      "group": "detail-hero",
      "interaction": "展示当前商品视觉主图",
      "default_state": "visible",
      "editable": false,
      "key_states": [
        "default"
      ]
    },
    {
      "content_id": "content-detail-summary",
      "content": "价格、标题、说明、规格与主操作按钮",
      "group": "detail-summary",
      "interaction": "可加入选货单或联系店主",
      "default_state": "visible",
      "editable": false,
      "key_states": [
        "default"
      ]
    },
    {
      "content_id": "content-detail-origin",
      "content": "当前商品来自哪条动态及其文案来源",
      "group": "detail-origin",
      "interaction": "帮助用户回溯发布上下文",
      "default_state": "visible",
      "editable": false,
      "key_states": [
        "原动态无文案时显示兜底说明"
      ]
    },
    {
      "content_id": "content-sheet-actions",
      "content": "筛选或更多操作项列表",
      "group": "overlay-actions",
      "interaction": "轻量点击后关闭并反馈",
      "default_state": "hidden",
      "editable": false,
      "key_states": [
        "open"
      ]
    }
  ],
  "states": [
    {
      "state_id": "state-feed-stable",
      "applies_to": [
        "surface-feed"
      ],
      "description": "动态项在文案为空、图片数量不同、商品标题较长时都保持稳定卡片节奏"
    }
  ],
  "transitions": [
    {
      "transition_id": "transition-feed-to-detail",
      "from": "node-feed-list",
      "trigger": "点击商品卡或去看看",
      "to": "node-product-detail",
      "data_in": [
        "product_id"
      ],
      "result_out": [
        "详情页展示"
      ],
      "return_to": "node-feed-list",
      "return_payload": [
        "保留列表滚动和选择状态"
      ]
    },
    {
      "transition_id": "transition-feed-to-sheet",
      "from": "node-feed-list",
      "trigger": "点击筛选或更多操作",
      "to": "node-action-sheet",
      "data_in": [
        "current_context"
      ],
      "result_out": [
        "操作反馈"
      ]
    }
  ],
  "data_handoffs": [
    {
      "handoff_id": "handoff-selected-product",
      "transition_id": "transition-feed-to-detail",
      "source_node": "node-feed-list",
      "target_node": "node-product-detail",
      "payload_content_refs": [
        "content-feed-cards"
      ],
      "reset_policy": "keep"
    }
  ],
  "exit_results": [
    "进入商品详情",
    "加入选货单成功反馈",
    "轻量操作反馈"
  ],
  "prototype_boundaries": [
    {
      "node_id": "node-feed-list",
      "depth": "functional",
      "feedback": "使用本地模拟数据实现连续浏览和点击跳转"
    },
    {
      "node_id": "node-product-detail",
      "depth": "functional",
      "feedback": "详情页支持返回、加入选货单和联系店主反馈"
    },
    {
      "node_id": "node-action-sheet",
      "depth": "simulated",
      "feedback": "保留筛选和更多操作入口，点击后以反馈代替真实业务联动"
    }
  ],
  "prototype_target": {
    "app_root": "wego-app",
    "scenario_folder": "wego-app/scenes/动态商品流",
    "routes": [
      {
        "id": "album-product-feed",
        "surface_ref": "surface-feed"
      },
      {
        "id": "album-product-detail",
        "surface_ref": "surface-detail"
      }
    ]
  },
  "host_container": {
    "type": "tab-host",
    "tab": "dongtai",
    "leaf_level": 2
  },
  "assumptions": [
    "动态流使用静态模拟数据，不接真实接口",
    "筛选和更多操作以原型反馈为主"
  ],
  "open_questions": [],
  "readiness": {
    "status": "ready-with-assumptions",
    "reason": "核心浏览和详情承接已明确，真实接口与高级筛选采用低风险可逆假设。",
    "affected_scope": [
      "静态模拟数据",
      "轻量操作反馈"
    ]
  },
  "rule_sources": [
    "用户需求",
    "AGENTS.md",
    ".codex/skills/wego-product/SKILL.md"
  ]
}

