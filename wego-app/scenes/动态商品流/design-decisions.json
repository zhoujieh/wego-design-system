    "state_contract": [
      {
        "state_id": "feed_loaded",
        "initial": true,
        "trigger": "场景挂载后自动加载本地模拟数据",
        "visible_result": "动态列表展示 5 条模拟动态，每条含发布者、时间、文案（可选）、图片（0-4 张）和产品信息",
        "fallback": "数据为空时展示空状态文案",
        "persistence": "session"
      },
