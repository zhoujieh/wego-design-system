  "prototype_brief": {
    "goal": "让用户在微购相册中连续浏览店主发布的商品动态，每条动态稳定呈现发布者、发布时间、商品内容、商品图片与相关产品信息，并支持进入产品详情或执行必要操作",
    "included": [
      "动态商品流浏览场景：连续浏览店主发布的商品动态",
      "每条动态稳定呈现：发布者、发布时间、商品内容、商品图片、相关产品信息",
      "兼容只有产品信息 / 同时含文字两种动态形态",
      "兼容文字为空、图片数量不同、产品信息较长时的稳定展示",
      "进入产品详情入口",
      "必要操作入口：一键转发（核心操作）、复制文案、分享、收藏、下载图片、搜索、编辑、复制动态、图片点击看大图"
    ],
    "excluded": [
      "发布动态、评论点赞等社交互动",
      "必要操作的具体功能实现（本轮只放入口，不下钻）",
      "真实后端接口与持久化"
    ],
    "entry_points": [
      "动态主 tab：作为底部导航「动态」tab 的内容，打开 App 即默认进入"
    ],
    "critical_paths": [
      "进入动态流 → 连续浏览动态 → 进入产品详情",
      "进入动态流 → 连续浏览动态 → 执行必要操作"
    ],
    "prototype_boundaries": [
      "动态商品流浏览场景 functional：可连续浏览、动态状态真实可操作",
      "产品详情 simulated：本地模拟数据展示基本产品信息",
      "必要操作入口 stub：本轮只呈现入口与明确反馈，不下钻具体功能实现"
    ],
    "assumptions": [
      {
        "statement": "假设用户已登录，打开 App 默认进入动态流",
        "impact_level": "low",
        "reversible": true
      },
      {
        "statement": "动态、产品详情与必要操作均使用本地模拟数据，不连接真实后端",
        "impact_level": "low",
        "reversible": true
      }
    ],
    "open_questions": []
  },
  "prototype_design": {
    "surface_decisions": [
      {
        "surface_id": "dongtai-feed",
        "presentation": "host-tab",
        "matched_blueprint": "continuous-content-feed-page",
        "layout_contract": {
          "page_edge_mode": "M0",
          "page_edge_mode_reason": "动态字段多但主任务是连续浏览；M0 通栏白底让每条动态以分隔线分组而非卡片堆叠，避免 M16 卡片压缩打断浏览节奏；命中 continuous-content-feed-page defaultExpectation=M0 或 M8",
          "media_priority": "supporting",
          "media_priority_reason": "每条动态同时承载发布者、时间、正文、产品摘要和操作；商品图片辅助用户快速判断是否下钻，不主导单条内容首屏高度；正文与产品摘要优先占位",
          "first_screen_content_rule": "首屏直接呈现动态流第一条完整动态：发布者头像+名称、发布时间、正文（如有）、商品图片网格、相关产品摘要卡片、操作行（一键转发+更多）；顶部固定搜索栏；不写导览、说明或原型解释",
          "optional_content_policy": "正文为空时折叠正文区域，不补'暂无文案'；图片为 0 张时折叠图片网格；产品信息较长时产品摘要卡片截断并保留'查看详情'入口；不自动补'未填写''暂无'或原型解释"
        },
        "component_mapping": [
          {
            "component": "search",
            "variant": "search-toolbar + searchbox--md searchbox--gray",
            "role": "页面顶部固定搜索栏，点击/输入触发搜索 stub 反馈"
          },
          {
            "component": "avatar",
            "variant": "avatar--40 avatar--image",
            "role": "动态发布者头像"
          },
          {
            "component": "image",
            "variant": "wg-image--custom-rect/custom-wide wg-image--rounded-md wg-image--clickable",
            "role": "商品图片，1-9 张自适应网格；点击触发大图查看 stub"
          },
          {
            "component": "card",
            "variant": "基础卡片",
            "role": "相关产品摘要卡片，只作内容分组；不新增 .card__media/.card__price 等业务子元素"
          },
          {
            "component": "tag",
            "variant": "tag--28 tag--brand / tag--gray",
            "role": "产品标签、动态类型标记"
          },
          {
            "component": "metric",
            "variant": "metric--marketing",
            "role": "产品价格展示"
          },
          {
            "component": "link",
            "variant": "link--standalone",
            "role": "产品摘要卡片右侧'查看详情'文字操作，承载下钻入口"
          },
          {
            "component": "button",
            "variant": "btn--weak btn--sm",
            "role": "一键转发，外露在动态操作行右侧（核心操作）"
          },
          {
            "component": "actionsheet",
            "variant": "标准 actionsheet",
            "role": "操作行'更多'触发，收纳 3+ 次级操作（见 dongtai-actions surface）"
          },
          {
            "component": "toast",
            "variant": "toast--default",
            "role": "操作反馈：复制成功、收藏成功、下载图片等 stub 反馈"
          }
        ],
        "interaction_notes": [
          "动态卡片整体可点击进入产品详情（push）",
          "商品图片点击触发大图查看 stub：openFullScreenModal 展示大图 + toast'图片大图查看（stub）'",
          "搜索栏输入后 toast'搜索：{关键词}（stub）'",
          "操作行布局：左侧'更多'图标按钮 → 右侧一键转发 weak 按钮（space-between，核心操作靠右）"
        ],
