  "scope_revision": 1,
  "prototype_brief": {
    "goal": "为微购相册提供一个可连续浏览的动态商品流，让用户快速扫读店主动态并进入商品详情或执行轻操作。",
    "included": [
      "动态 Tab 宿主内连续商品流浏览",
      "单条动态展示发布者、发布时间、正文、商品图片和商品摘要",
      "支持无正文、多图和长商品信息的稳定呈现",
      "从动态流进入商品详情",
      "列表轻操作与更多操作收口"
    ],
    "excluded": [
      "真实下单链路",
      "服务端分页与刷新",
      "评论、点赞、私信等社交能力"
    ],
    "entry_points": [
      "底部 Tab「动态」默认进入动态商品流",
      "动态卡片内商品摘要与轻操作可触发下钻或操作"
    ],
    "critical_paths": [
      "进入动态 Tab后连续浏览多条商品动态并判断是否下钻",
      "点击商品摘要进入商品详情查看完整商品信息",
      "在不打断浏览节奏的前提下执行询价、转发等轻操作"
    ],
    "prototype_boundaries": [
      "使用本地模拟动态数据与商品数据",
      "详情页操作以 toast 模拟反馈",
      "更多操作通过 sheet 收口，不接真实分享能力"
    ],
    "assumptions": [
      "当前阶段以单店主发布流为主，不引入跨店铺混排",
      "用户更关注扫读效率与商品判断，不需要列表内强购买按钮"
    ],
    "open_questions": []
  },
