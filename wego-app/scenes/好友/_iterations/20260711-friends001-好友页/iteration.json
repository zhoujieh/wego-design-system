  "prototype_brief": {
    "goal": "在微购 App 原型中建立好友主 Tab 页，集中展示当前用户的有效好友，支持搜索、排序，展示好友商品数据（上新数量、商品总数），数据本地持久化。",
    "included": [
      "好友主 Tab 页面：绑定宿主已有的 haoyou Tab，直接作为一级页面展示",
      "好友搜索：按好友名称、好友昵称、店铺名称搜索，搜索区展示当前好友总数（如「搜索 571 个好友」）",
      "全部好友：展示当前用户所有有效好友，不含已解除关系用户",
      "好友信息展示：好友 ID、名称、头像、关系类型、VIP 状态、认证状态、上新商品数量、商品总数量",
      "好友排序：默认按新增顺序，点击排序切换为按字母排序",
      "好友数据本地持久化：使用 localStorage 存储，刷新页面后数据保留",
      "空数据场景：暂无好友、搜索无结果",
      "异常场景：好友数据获取失败、搜索失败、商品数据获取失败"
    ],
    "excluded": [
      "等待推上新相关功能（状态标识、数量、列表）",
      "星标好友功能",
      "好友详情页下钻",
      "好友分类功能（粉丝与客户/帮卖代理/供应商/推广员，分类为独立二级页，本期不做）",
      "好友分组功能",
      "真实好友接口",
      "登录权限与身份校验",
      "消息推送",
      "生产部署"
    ],
    "entry_points": [
      {
        "id": "friends-tab",
        "carrier": "host-fixed-tab",
        "description": "绑定宿主已有的 haoyou Tab（index.html 中 data-host-tab=haoyou），在 routes.js 注册 host-tab 类型 route，点击切换到好友宿主页，稳定 route_id 为 friends"
      }
    ],
    "critical_paths": [
      "进入好友 Tab → 浏览全部好友列表 → 查看好友商品数据（上新数/总数）",
      "进入好友 Tab → 搜索好友（名称/昵称/店铺名）→ 查看搜索结果",
      "进入好友 Tab → 切换排序方式 → 查看排序后的好友列表"
    ],
    "prototype_boundaries": [
      "好友数据使用 localStorage 本地持久化，刷新页面后保留",
      "异常场景用本地模拟错误状态展示，不接入真实接口",
      "好友排序在两种模式间切换：新增顺序、字母排序"
    ],
    "assumptions": [
      {
        "description": "好友商品数据（上新数量/商品总数）由本地模拟，与好友列表持久化存储保持一致。"
      }
    ],
    "open_questions": []
  },
