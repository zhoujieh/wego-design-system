{
  "goal": "让店主管理交易相关配置，包括收款播报、库存、下单模式、零售记账、在线收款、订单规则和打印设备等能力；开关即时生效，下钻入口按原型边界处理。",
  "scope": {
    "included": ["从系统设置进入交易设置", "交易设置列表", "开关类配置即时切换", "下钻入口 stub 反馈", "返回系统设置"],
    "excluded": ["真实支付配置", "打印设备连接", "订单规则深层配置", "后端持久化"]
  },
  "actors": ["店主", "超级管理员"],
  "entry_points": [
    { "id": "system-settings-trade-entry", "label": "交易设置", "location": "系统设置列表", "route_id": "my-trade-settings", "surface_ref": "host-entry" }
  ],
  "flows": [
    { "id": "configure-trade-settings", "type": "main", "goal": "进入交易设置并调整交易规则", "nodes": ["enter-trade-settings", "view-trade-setting-list", "toggle-trade-setting", "return-system-settings"] },
    { "id": "open-trade-stub-entry", "type": "branch", "goal": "点击未接入交易配置时给出反馈", "nodes": ["view-trade-setting-list", "tap-trade-stub", "show-stub-toast"] }
  ],
  "flow_nodes": [
    { "id": "enter-trade-settings", "surface_ref": "host-entry", "purpose": "从系统设置进入交易设置" },
    { "id": "view-trade-setting-list", "surface_ref": "trade-setting-list", "purpose": "查看交易设置分组" },
    { "id": "toggle-trade-setting", "surface_ref": "trade-setting-list", "purpose": "切换交易开关并即时更新内存状态" },
    { "id": "tap-trade-stub", "surface_ref": "trade-setting-list", "purpose": "点击暂未接入的交易配置入口" },
    { "id": "show-stub-toast", "surface_ref": "trade-setting-list", "purpose": "展示功能尚未接入反馈" },
    { "id": "return-system-settings", "surface_ref": "host-entry", "purpose": "返回系统设置" }
  ],
  "surfaces": [
    { "id": "host-entry", "type": "internal-entry", "carrier": "system-settings-list", "route_id": "my-trade-settings", "role": "系统设置内的交易设置入口" },
    { "id": "trade-setting-list", "type": "page", "carrier": "push-route", "route_id": "my-trade-settings", "role": "交易设置列表" }
  ],
  "content_blocks": [
    { "id": "payment-broadcast", "surface_ref": "trade-setting-list", "content": "收款播报", "interaction": "toggle", "default_state": "on" },
    { "id": "inventory-deduction", "surface_ref": "trade-setting-list", "content": "库存扣减", "interaction": "toggle", "default_state": "on" },
    { "id": "order-mode", "surface_ref": "trade-setting-list", "content": "下单模式", "interaction": "stub" },
    { "id": "retail-accounting", "surface_ref": "trade-setting-list", "content": "零售记账", "interaction": "toggle", "default_state": "on" },
    { "id": "online-payment", "surface_ref": "trade-setting-list", "content": "在线收款", "interaction": "stub" },
    { "id": "order-rules", "surface_ref": "trade-setting-list", "content": "订单规则", "interaction": "stub" },
    { "id": "print-device", "surface_ref": "trade-setting-list", "content": "打印设备", "interaction": "stub" }
  ],
  "states": [
    { "id": "default", "description": "展示交易设置默认状态" },
    { "id": "setting-changed", "description": "开关切换后即时更新视觉和内存状态" },
    { "id": "stub-feedback", "description": "暂未接入入口展示 toast" }
  ],
  "transitions": [
    { "id": "open-trade-settings", "from": "enter-trade-settings", "trigger": "tap-trade-settings", "to": "view-trade-setting-list", "route_id": "my-trade-settings" },
    { "id": "toggle-trade-setting", "from": "view-trade-setting-list", "trigger": "tap-switch", "to": "toggle-trade-setting", "result_out": ["switch-state"] },
    { "id": "stub-trade-entry", "from": "view-trade-setting-list", "trigger": "tap-stub-entry", "to": "show-stub-toast", "result_out": ["toast"] },
    { "id": "back-system-settings", "from": "view-trade-setting-list", "trigger": "tap-back", "to": "return-system-settings", "return_to": "my-system-settings" }
  ],
  "data_handoffs": [
    { "id": "trade-switch-state-memory", "from": "toggle-trade-setting", "to": "trade-setting-list", "data": ["switch-state"], "persistence": "memory-only" }
  ],
  "exit_results": ["交易设置状态在原型内更新", "未接入入口有明确反馈", "可返回系统设置"],
  "prototype_target": {
    "app_root": "wego-app",
    "scenario_folder": "wego-app/scenes/交易设置",
    "routes": [{ "id": "my-trade-settings", "surface_ref": "trade-setting-list" }]
  },
  "prototype_boundaries": [
    { "node_id": "toggle-trade-setting", "depth": "functional", "reason": "开关类配置需要真实切换状态" },
    { "node_id": "tap-trade-stub", "depth": "stub", "reason": "深层交易配置不在本次范围" }
  ],
  "assumptions": [
    { "id": "memory-only", "description": "交易设置仅在原型内维护内存状态，不接真实支付、打印或订单服务。", "impact_level": "medium", "reversible": true }
  ],
  "open_questions": [],
  "readiness": { "status": "ready-with-assumptions", "reason": "旧规格已定义交易设置范围；高风险真实交易能力按 stub 边界处理。" }
}
