{
  "task_type": "design-system-consumption",
  "scene_category": "form-edit",
  "goal": "让店主以连续文本输入方式快速录入并识别产品字段，保存文本与结构化识别结果，发布后在动态页即时展示，并支持从动态页再次进入编辑继续增量识别和修改",
  "scope": {
    "included": [
      "动态 Tab 导航栏右上角发布入口",
      "快捷发布产品全屏编辑页：产品名、售价、货号、规格、颜色、重量、库存、标签、来源共 9 行连续文本编辑器",
      "空格/Enter 增量识别、局部闪烁反馈、去重提示、光标保持",
      "可见性切换、图片上传占位",
      "原始文本与结构化识别结果持久化（localStorage，降级会话内存）",
      "发布成功后回到动态页，列表顶部即时展示新增产品",
      "动态产品卡片展示必要摘要，点击卡片再次进入同一产品编辑"
    ],
    "excluded": [
      "图片上传真实业务实现（仅占位）",
      "动态页完整筛选、搜索、九宫格等能力（属动态场景）",
      "产品详情页",
      "分类选择、运费模板等下钻子流程"
    ]
  },
  "actors": [
    { "id": "shop-owner", "role": "店主", "purpose": "快速录入并发布产品，后续可再次编辑" }
  ],
  "entry_points": [
    {
      "id": "dongtai-publish-btn",
      "carrier": "navbar-action",
      "description": "动态 Tab 导航栏右上角发布按钮，点击打开全屏编辑模态"
    }
  ],
  "interaction_mode": "edit-then-save",
  "app_target": {
    "mode": "wego-app-scene",
    "app_root": "wego-app",
    "scene_folder": "wego-app/scenes/快捷发布产品",
    "runtime_entry": "scene.js",
    "route_mode": "hash"
  },
  "host_container": {
    "tab": "dongtai",
    "entry_label": "发布",
    "subentry_label": "",
    "leaf_level": 2,
    "entry_type": "cell",
    "needs_host_entry_surface": true
  },
  "prototype_target": {
    "app_root": "wego-app",
    "scenario_folder": "wego-app/scenes/快捷发布产品",
    "routes": [
      { "id": "quick-publish-product", "surface_ref": "quick-publish-form" }
    ]
  },
  "flows": [
    {
      "flow_id": "publish-product",
      "flow_type": "main",
      "entry_node": "enter-publish-entry",
      "steps": ["enter-publish-entry", "edit-product-fields", "recognize-fields", "submit-publish", "view-published-summary"],
      "exit_condition": "发布成功并回到动态页展示新产品"
    },
    {
      "flow_id": "re-edit-product",
      "flow_type": "branch",
      "entry_node": "view-published-summary",
      "steps": ["view-published-summary", "re-edit-product", "submit-publish", "view-published-summary"],
      "exit_condition": "编辑保存后回到动态页，原产品更新"
    },
    {
      "flow_id": "cancel-edit",
      "flow_type": "interrupt-resume",
      "entry_node": "edit-product-fields",
      "steps": ["edit-product-fields", "cancel-edit"],
      "exit_condition": "取消编辑并回到动态页，不产生新产品"
    }
  ],
  "flow_nodes": [
    {
      "node_id": "enter-publish-entry",
      "purpose": "从动态 Tab 导航栏右上角发布按钮进入编辑页",
      "surface_ref": "dongtai-navbar-entry",
      "inputs": [],
      "outputs": ["编辑页打开"],
      "key_states": ["动态页已加载", "编辑页打开"]
    },
    {
      "node_id": "edit-product-fields",
      "purpose": "在连续文本编辑器中录入产品名、售价、货号、规格、颜色、重量、库存、标签、来源",
      "surface_ref": "quick-publish-form",
      "inputs": ["可选 productId（再次编辑时）"],
      "outputs": ["rawText", "结构化 items"],
      "key_states": ["空表单", "部分填写", "再次编辑恢复原文本与结构化项"]
    },
    {
      "node_id": "recognize-fields",
      "purpose": "空格或 Enter 触发当前词识别，保持光标位置，局部闪烁反馈，去重提示",
      "surface_ref": "quick-publish-form",
      "inputs": ["rawText", "光标位置"],
      "outputs": ["更新后的 items", "闪烁动画", "去重提示"],
      "key_states": ["识别中", "识别完成", "重复提示"]
    },
    {
      "node_id": "submit-publish",
      "purpose": "点击发布按钮，统一保存 rawText 与结构化 items，持久化并触发动态页回填",
      "surface_ref": "quick-publish-form",
      "inputs": ["rawText", "items", "visibility"],
      "outputs": ["saved product id"],
      "key_states": ["提交中（按钮禁用）", "保存成功", "保存失败重试"]
    },
    {
      "node_id": "view-published-summary",
      "purpose": "发布成功后回到动态页，新产品显示在列表顶部，点击卡片可再次编辑",
      "surface_ref": "published-product-summary",
      "inputs": ["saved product id"],
      "outputs": ["动态列表更新", "产品卡片摘要"],
      "key_states": ["列表有数据", "空态"]
    },
    {
      "node_id": "re-edit-product",
      "purpose": "点击动态卡片进入同一产品编辑，恢复原文本与结构化项，保存更新原产品而非新增",
      "surface_ref": "quick-publish-form",
      "inputs": ["productId"],
      "outputs": ["更新后的 product"],
      "key_states": ["恢复原数据", "编辑中", "保存更新"]
    },
    {
      "node_id": "cancel-edit",
      "purpose": "点击取消按钮放弃当前编辑，回到动态页，不产生新产品",
      "surface_ref": "quick-publish-form",
      "inputs": [],
      "outputs": ["回到动态页"],
      "key_states": ["取消确认", "已返回"]
    },
    {
      "node_id": "upload-image",
      "purpose": "图片上传占位入口，仅提供反馈不真实上传",
      "surface_ref": "quick-publish-form",
      "inputs": [],
      "outputs": ["toast 反馈"],
      "key_states": ["占位"]
    }
  ],
  "surfaces": [
    {
      "surface_id": "dongtai-navbar-entry",
      "role": "host-entry",
      "carrier": "host-section",
      "node_refs": ["enter-publish-entry"],
      "content_refs": ["publish-entry-trigger", "dynamic-empty-state"],
      "interaction_mode": "instant-apply",
      "purpose": "承接快捷发布入口，并在宿主动态页展示已发布产品列表与空态",
      "states": ["动态页已加载", "空态"]
    },
    {
      "surface_id": "quick-publish-form",
      "role": "primary-task-page",
      "carrier": "standalone-page",
      "node_refs": ["edit-product-fields", "recognize-fields", "submit-publish", "re-edit-product", "cancel-edit", "upload-image"],
      "content_refs": ["navbar-cancel", "navbar-publish-action", "field-product-name", "field-price", "field-sku", "field-spec", "field-color", "field-weight", "field-stock", "field-tag", "field-source", "visibility-toggle", "image-upload-placeholder"],
      "interaction_mode": "edit-then-save",
      "purpose": "采集产品字段，在不中断连续输入的前提下完成识别、修改、去重和保存",
      "states": ["空表单", "部分填写", "再次编辑恢复", "提交中", "重复提示"]
    },
    {
      "surface_id": "published-product-summary",
      "role": "result-summary",
      "carrier": "host-section",
      "node_refs": ["view-published-summary"],
      "content_refs": ["dynamic-product-card"],
      "interaction_mode": "view-only",
      "purpose": "提供发布结果回填和产品再次编辑入口，保证新增、展示、编辑形成完整闭环",
      "states": ["列表有数据", "空态"]
    }
  ],
  "content_blocks": [
    {
      "content_id": "publish-entry-trigger",
      "content": "动态 Tab 导航栏右上角发布按钮",
      "group": "入口",
      "interaction": "action",
      "editable": false,
      "key_states": ["默认"]
    },
    {
      "content_id": "dynamic-empty-state",
      "content": "动态页无产品时的空态展示",
      "group": "入口",
      "interaction": "view",
      "editable": false,
      "key_states": ["空态"]
    },
    {
      "content_id": "navbar-cancel",
      "content": "导航栏左侧取消操作，放弃当前编辑回到动态页",
      "group": "导航栏",
      "interaction": "action",
      "editable": false,
      "key_states": ["默认"]
    },
    {
      "content_id": "navbar-publish-action",
      "content": "导航栏右侧唯一发布主操作，提交期间禁用避免重复创建产品",
      "group": "导航栏",
      "interaction": "action",
