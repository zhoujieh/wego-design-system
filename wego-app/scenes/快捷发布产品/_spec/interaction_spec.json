      "content": "动态产品卡片，展示产品名、价格、规格、颜色、标签、来源、可见性和发布时间中的有效信息，未填写字段不占位；点击卡片再次进入同一产品编辑",
      "group": "动态结果",
      "interaction": "action",
      "editable": false,
      "key_states": ["新增产品", "已更新产品", "空字段不占位"]
    }
  ],
  "transitions": [
    {
      "transition_id": "t-open-editor",
      "from": "enter-publish-entry",
      "trigger": "点击动态导航栏发布按钮",
      "to": "edit-product-fields",
      "data_in": [],
      "result_out": ["编辑页打开"],
      "return_to": null
    },
    {
      "transition_id": "t-recognize",
      "from": "edit-product-fields",
      "trigger": "空格或 Enter 触发当前词识别",
      "to": "recognize-fields",
      "data_in": ["rawText", "光标位置"],
      "result_out": ["更新后的 items", "闪烁动画"],
      "return_to": "edit-product-fields"
    },
    {
      "transition_id": "t-submit-publish",
      "from": "recognize-fields",
      "trigger": "点击导航栏发布按钮",
      "to": "submit-publish",
      "data_in": ["rawText", "items", "visibility"],
      "result_out": ["saved product id"],
      "return_to": null
    },
    {
      "transition_id": "t-publish-success",
      "from": "submit-publish",
      "trigger": "保存成功",
      "to": "view-published-summary",
      "data_in": ["saved product id"],
      "result_out": ["动态列表顶部新增产品", "切回 dongtai Tab", "关闭全屏场景"],
      "return_to": "view-published-summary"
    },
    {
      "transition_id": "t-re-edit",
      "from": "view-published-summary",
      "trigger": "点击动态卡片",
      "to": "re-edit-product",
      "data_in": ["productId"],
      "result_out": ["恢复原文本与结构化项"],
      "return_to": "view-published-summary"
    },
    {
      "transition_id": "t-cancel-edit",
      "from": "edit-product-fields",
      "trigger": "点击导航栏取消",
      "to": "cancel-edit",
      "data_in": [],
      "result_out": ["回到动态页"],
      "return_to": null
    }
  ],
  "data_handoffs": [
    {
      "handoff_id": "handoff-publish-result",
      "transition_id": "t-publish-success",
      "source_node": "submit-publish",
      "target_node": "view-published-summary",
      "payload_content_refs": ["dynamic-product-card"],
      "reset_policy": "clear-on-success",
      "description": "发布成功后 productId 与字段传递到动态页，列表顶部新增产品卡片，编辑页状态清空"
    },
    {
      "handoff_id": "handoff-re-edit-product",
      "transition_id": "t-re-edit",
      "source_node": "view-published-summary",
      "target_node": "re-edit-product",
      "payload_content_refs": ["dynamic-product-card"],
      "reset_policy": "keep",
      "description": "点击卡片携带 productId 进入编辑页，恢复原 rawText 与 items，保存更新原产品而非新增"
    }
  ],
  "prototype_boundaries": [
    {
      "node_id": "enter-publish-entry",
      "depth": "simulated",
      "reason": "使用本地导航栏按钮触发，不依赖真实后端"
    },
    {
      "node_id": "edit-product-fields",
      "depth": "functional",
      "reason": "连续文本录入、光标保持、原位置更新、删除同步均为真实可操作"
    },
    {
      "node_id": "recognize-fields",
      "depth": "functional",
      "reason": "空格/Enter 增量识别、局部闪烁、去重提示、尺码区间展开均为真实逻辑"
    },
    {
      "node_id": "submit-publish",
      "depth": "functional",
      "reason": "统一保存 rawText 与 items，持久化到 localStorage（降级会话内存），触发动态页回填",
      "feedback": "保存成功后 toast 提示「发布成功」"
    },
    {
      "node_id": "view-published-summary",
      "depth": "functional",
      "reason": "动态列表真实更新，卡片展示有效字段，点击进入再编辑"
    },
    {
      "node_id": "re-edit-product",
      "depth": "functional",
      "reason": "恢复原文本与结构化项，保存更新原产品 id，不新增重复动态"
    },
    {
      "node_id": "cancel-edit",
      "depth": "functional",
      "reason": "取消真实关闭场景并回动态页，不产生新产品"
    },
    {
      "node_id": "upload-image",
      "depth": "stub",
      "reason": "图片上传仅为占位入口，不接入真实上传能力",
      "feedback": "toast 提示「该功能尚未接入原型」"
    }
  ],
  "states": [
    { "id": "empty-form", "description": "编辑页初始空表单" },
    { "id": "partial-filled", "description": "部分字段已填写" },
    { "id": "submitting", "description": "发布提交中，按钮禁用" },
    { "id": "publish-success", "description": "发布成功，回动态页展示新产品" },
    { "id": "re-editing", "description": "再次编辑原产品，恢复原数据" },
    { "id": "duplicate-prompt", "description": "重复内容提示" },
    { "id": "format-error", "description": "数字格式错误提示" }
  ],
  "assumptions": [
    {
      "assumption": "需求明确要求跨会话继续编辑，使用 localStorage 持久化 rawText 与 items；不可用时降级为当前会话内存状态",
      "impact_level": "low",
      "reversible": true
    },
    {
      "assumption": "局部闪烁优先使用 CSS Custom Highlight API，不支持时使用临时无样式 span 兜底，并在移除前后恢复选区",
      "impact_level": "low",
      "reversible": true
    },
    {
      "assumption": "图片上传为占位交互，动态卡片在没有图片时使用低干扰文字识别图",
      "impact_level": "low",
      "reversible": true
    }
  ],
  "open_questions": [],
  "readiness": {
    "status": "ready-with-assumptions",
    "reason": "业务目标、流程、状态、宿主路径和数据回填均明确；仅有低风险可逆假设（持久化降级、闪烁兜底、图片占位）"
  },
  "rule_sources": [
