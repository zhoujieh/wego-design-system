    { "source": "existing-interaction-spec", "supports": ["归档 page_spec.20260709-1930.json 的 business_goal、information_blocks、page_surfaces、host_container、route_id"] },
    { "source": "AGENTS.md", "supports": ["wego-app 唯一宿主、hash route_id、场景目录复用、不依赖 fetch/XHR"] },
    { "source": "wego-product/SKILL.md", "supports": ["interaction_spec Stage 2 结构：flows/flow_nodes/surfaces/content_blocks/transitions/data_handoffs/prototype_boundaries/readiness", "host_container.entry_type 必须为 cell|grid-entry", "prototype_target.routes[] 替代单一 route_id"] }
