{
  "schemaVersion": 3,
  "scene": "快捷发布产品",
  "route_id": "quick-publish-product",
  "page_presentation": {
    "type": "full-screen-modal",
    "transition": "slide-up",
    "coversTabBar": true
  },
  "component_mapping": [
    {
      "element": "快捷发布页导航栏",
      "component": "navbar",
      "variant": {
        "leftControl": "text-cancel",
        "titleAlignment": "center",
        "actions": "button",
        "rightActionType": "button",
        "spacing": "spaced",
        "pageTransition": "present",
        "position": "sticky"
      },
      "consumption_mode": "stable-variant",
      "notes": "左侧取消文本，右侧发布按钮使用 button 组件 strong/sm"
    },
    {
      "element": "发布按钮",
      "component": "button",
      "variant": {
        "emphasis": "strong",
        "size": "sm",
        "iconMode": "text-only"
      },
      "consumption_mode": "stable-variant"
    },
    {
      "element": "编辑器行",
      "component": "custom",
      "variant": {},
      "consumption_mode": "free-composition",
      "notes": "当前无直接契约覆盖左右标签+透明输入框的多行编辑器，使用页面级自定义结构；标签使用 body-lg 字号，输入框透明无边框"
    },
    {
      "element": "辅助入口按钮",
      "component": "custom",
      "variant": {},
      "consumption_mode": "free-composition",
      "notes": "标签、来源、可见性入口为轻量胶囊按钮，使用 bg-subtle 背景，不属于 button 组件标准变体"
    }
  ],
  "token_usage": [
    "--bg-surface",
    "--bg-subtle",
    "--bg-overlay-l1",
    "--text-default",
    "--text-secondary",
    "--text-placeholder",
    "--text-brand",
    "--border-neutral-l2",
    "--body-lg-font-size",
    "--body-md-font-size",
    "--body-sm-font-size",
    "--spacer-4",
    "--spacer-8",
    "--spacer-12",
    "--spacer-16",
    "--spacer-40",
    "--radius-4",
    "--radius-6",
    "--radius-8",
    "--safe-area-bottom"
  ],
  "composition_notes": [
    "页面背景声明为 data-bg=surface（白色），导航栏自动继承白底",
    "编辑器区域与辅助入口、图片上传按纵向 16px 间距排列",
    "底部预留 safe-area + 40px 内容间距",
    "规格/颜色行使用自定义标签识别逻辑：按空格分词、去重、新词播放浅绿色闪烁动画"
  ],
  "risks": [
    "输入区域为自定义 contenteditable 结构，未命中 input 组件标准标签在上布局；已保持字号、颜色使用 Token",
      "动态导航栏设计稿未能通过 MCP 读取，当前按左侧 VIP/SVIP 图标 + 右侧发布按钮实现，具体尺寸待确认",
      "标签闪烁动画使用自定义 keyframes，非 design-system 标准动效",
      "标签以内联方式嵌入 contenteditable，通过 JS 按空格分词、去重、新词添加闪烁动画"
    ]
}
