  "prototype_brief": {
    "goal": "让店主快速找到并管理微购好友，并了解好友作为店主的上新动态和商品规模。",
    "included": [
      "浏览好友：每个好友展示头像、昵称、上新数量和产品总数",
      "按昵称搜索好友，支持模糊匹配",
      "排序切换：支持字母排序和分组排序两种维度",
      "字母排序：按昵称拼音首字母 A-Z 聚合",
      "分组排序：按用户自定义好友分组聚合，分组内默认按昵称拼音首字母排序",
      "快速跳转：提供与当前排序维度联动的快速跳转能力，字母排序下可跳转到各拼音首字母位置，分组排序下可跳转到各自定义分组位置",
      "添加好友入口及完整新建好友信息收集（含头像、昵称、账号或手机号、备注、所属分组、标签、来源渠道、验证留言）",
      "好友为空状态和搜索无结果状态"
    ],
    "excluded": [
      "好友详情页（本期点击好友无跳转事件）",
      "好友店铺动态和商品流跳转",
      "删除好友、编辑好友、移动分组",
      "好友消息和聊天",
      "真实后端数据持久化（原型用内置数据模拟）"
    ],
    "entry_points": [
      "好友主 tab，与动态、我的同级，用户打开 App 后可通过主 tab 切换进入"
    ],
    "critical_paths": [
      "进入好友 tab → 浏览好友 → 切换排序 → 通过快速跳转到达对应位置",
      "进入好友 tab → 搜索好友 → 查看匹配结果或无结果状态",
      "进入好友 tab → 添加好友 → 填写完整信息 → 提交成功 → 好友集合新增该好友"
    ],
