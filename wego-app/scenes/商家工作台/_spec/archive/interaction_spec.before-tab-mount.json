{
  "schemaVersion": 2,
  "task_type": "design-system-consumption",
  "scene_category": "other",
  "goal": "为商户提供移动端经营工作台，集中查看经营数据、处理订单待办、进入常用业务应用。",
  "business_goal": "商户在工作台首页快速查数据、开单、处理订单和进入运营应用。",
  "scope": {
    "included": [
      "单页工作台首页",
      "今日经营数据与昨日对比",
      "核心操作入口",
      "销售订单状态计数",
      "客户流失预警待办",
      "模块化应用中心入口",
      "流量与传播明细"
    ],
    "excluded": [
      "发布商品、采购、销售开单、发货、直播、报表、营销等完整二级子系统",
      "真实后端数据接入",
      "自定义操作拖拽排序和持久化配置"
    ]
  },
  "actors": [
    {
      "id": "merchant-operator",
      "name": "商户经营者",
      "needs": [
        "快速了解今日经营表现",
        "快速进入日常高频业务",
        "及时处理订单和客户待办"
      ]
    }
  ],
  "interaction_mode": "view-only",
  "app_target": {
    "mode": "wego-app-scene",
    "app_root": "wego-app",
    "scene_folder": "wego-app/scenes/商家工作台",
    "runtime_entry": "scene.js",
    "route_mode": "hash"
  },
  "host_container": {
    "tab": "workspace",
    "entry_label": "商家工作台",
    "subentry_label": "",
    "leaf_level": 1,
    "entry_type": "grid-entry",
    "needs_host_entry_surface": false
  },
  "prototype_target": {
    "app_root": "wego-app",
    "scenario_folder": "wego-app/scenes/商家工作台",
    "routes": [
      {
        "id": "workspace-merchant-workbench",
        "surface_ref": "merchant-workbench-main"
      }
    ]
  },
  "route_id": "workspace-merchant-workbench",
  "entry_points": [
    {
      "entry_id": "workspace-tab-entry",
      "tab": "workspace",
      "label": "商家工作台",
      "route_id": "workspace-merchant-workbench"
    }
  ],
  "flows": [
    {
      "flow_id": "view-workbench",
      "flow_type": "main",
      "entry_node": "enter-workbench",
      "steps": [
        "enter-workbench",
        "scan-business-data",
        "use-workbench-entry"
      ],
      "exit_condition": "商户完成查看数据或触发一个业务入口"
    },
    {
      "flow_id": "refresh-data-feedback",
      "flow_type": "branch",
      "entry_node": "scan-business-data",
      "steps": [
        "scan-business-data",
        "refresh-business-data"
      ],
      "exit_condition": "页面给出准实时刷新反馈"
    }
  ],
  "flow_nodes": [
    {
      "node_id": "enter-workbench",
      "purpose": "从工作台 Tab 进入商家工作台首页",
      "surface_ref": "merchant-workbench-main",
      "inputs": [
        "workspace-tab-entry"
      ],
      "outputs": [
        "workbench-visible"
      ],
      "key_states": [
        "正常进入",
        "路由脚本加载失败时由宿主提示"
      ]
    },
    {
      "node_id": "scan-business-data",
      "purpose": "查看经营数据、订单待办、客户待办和流量传播",
      "surface_ref": "merchant-workbench-main",
      "inputs": [
        "business-dashboard",
        "order-management",
        "customer-todo",
        "traffic-analytics"
      ],
      "outputs": [
        "business-status-understood"
      ],
      "key_states": [
        "有数据",
        "准实时更新中"
      ]
    },
    {
      "node_id": "use-workbench-entry",
      "purpose": "点击核心操作或应用中心入口",
      "surface_ref": "merchant-workbench-main",
      "inputs": [
        "core-actions",
        "app-center"
      ],
      "outputs": [
        "navigate-existing-route-or-stub-feedback"
      ],
      "key_states": [
        "已有路由跳转",
        "未展开子系统显示占位反馈"
      ]
    },
    {
      "node_id": "refresh-business-data",
      "purpose": "触发今日经营数据刷新反馈",
      "surface_ref": "merchant-workbench-main",
      "inputs": [
        "business-dashboard"
      ],
      "outputs": [
        "refresh-toast"
      ],
      "key_states": [
        "刷新成功反馈"
      ]
    }
  ],
  "surfaces": [
    {
      "surface_id": "merchant-workbench-main",
      "role": "primary-task-page",
      "carrier": "standalone-page",
      "node_refs": [
        "enter-workbench",
        "scan-business-data",
        "use-workbench-entry",
        "refresh-business-data"
      ],
      "content_refs": [
        "business-dashboard",
        "core-actions",
        "order-management",
        "customer-todo",
        "app-center",
        "traffic-analytics"
      ],
      "interaction_mode": "view-only",
      "purpose": "承载商户经营概览和业务入口集合",
      "states": [
        "有数据",
        "入口占位反馈",
        "刷新反馈"
      ]
    }
  ],
  "content_blocks": [
    {
      "content_id": "business-dashboard",
      "content": "经营数据看板，展示实收金额、销售单数、成交人数、访问人数、粉丝浏览量、员工业绩，并包含昨日对比和趋势。",
      "group": "核心经营数据看板",
      "interaction": "view",
      "editable": false,
      "default_state": "显示本地模拟今日数据",
      "key_states": [
        "显示昨日对比",
        "访问人数显示百分比涨跌",
        "刷新时显示准实时反馈"
      ]
    },
    {
      "content_id": "core-actions",
      "content": "发布商品、采购入库、销售开单、查库存、去发货、发起直播、AI 批量入库、自定义操作。",
      "group": "核心业务操作",
      "interaction": "action",
      "editable": false,
      "default_state": "展示八个常用入口",
      "key_states": [
        "发布商品跳转已有发布路由",
        "查库存跳转已有库存路由",
        "采购入库可跳转仓库管理",
        "未展开入口显示明确反馈"
      ]
    },
    {
      "content_id": "order-management",
      "content": "销售订单状态计数，包含待收款、待发货、已挂起、待售后，并提供全部销售单和收益查看入口。",
      "group": "销售订单管理",
      "interaction": "action",
      "editable": false,
      "default_state": "显示本地模拟订单数量",
      "key_states": [
        "订单状态入口显示占位反馈",
        "销售单可跳转已有销售单相关入口时使用跳转，否则显示反馈"
      ]
    },
    {
      "content_id": "customer-todo",
      "content": "客户流失预警数量、回访提醒和营销触达入口。",
      "group": "客户智能待办",
      "interaction": "action",
      "editable": false,
      "default_state": "显示即将流失客户数量和跟进建议",
      "key_states": [
        "回访入口显示占位反馈",
        "营销触达显示占位反馈"
      ]
    },
    {
      "content_id": "app-center",
      "content": "店铺管理、数据报表、进销存管理、营销中心、财务与客户等模块化应用入口。",
      "group": "模块化应用中心",
      "interaction": "action",
      "editable": false,
      "default_state": "按业务分组展示入口",
      "key_states": [
        "已有路由可跳转",
        "未展开应用显示占位反馈"
      ]
    },
    {
      "content_id": "traffic-analytics",
      "content": "分享到聊天、分享到朋友圈、今日新增粉丝、全部粉丝的当日数据和昨日对比。",
      "group": "流量与传播明细",
      "interaction": "view",
      "editable": false,
      "default_state": "显示本地模拟传播与粉丝数据",
      "key_states": [
        "显示昨日对比",
        "无真实数据接入时保持模拟状态"
      ]
    }
  ],
  "states": [
    {
      "state_id": "normal",
      "description": "工作台展示完整模拟数据和所有入口"
    },
    {
      "state_id": "stub-feedback",
      "description": "未实现子系统入口点击后展示 toast 反馈"
    },
    {
      "state_id": "refresh-feedback",
      "description": "刷新按钮点击后展示今日数据已更新反馈"
    }
  ],
  "edge_cases": [
    "重复点击未展开入口时只显示当前 toast，不产生重复页面",
    "已有路由跳转由宿主在 phone-screen 内打开",
    "自定义操作本轮不保存配置，只显示配置入口占位反馈"
  ],
  "transitions": [
    {
      "transition_id": "open-workbench-route",
      "from": "enter-workbench",
      "trigger": "点击工作台 Tab 下的商家工作台入口或访问 hash route",
      "to": "scan-business-data",
      "data_in": [
        "workspace-tab-entry"
      ],
      "result_out": [
        "workbench-visible"
      ],
      "return_to": "",
      "return_payload": []
    },
    {
      "transition_id": "click-entry",
      "from": "scan-business-data",
      "trigger": "点击核心操作、订单、待办或应用入口",
      "to": "use-workbench-entry",
      "data_in": [
        "core-actions",
        "order-management",
        "customer-todo",
        "app-center"
      ],
      "result_out": [
        "navigate-existing-route-or-stub-feedback"
      ],
      "return_to": "scan-business-data",
      "return_payload": []
    },
    {
      "transition_id": "refresh-dashboard",
      "from": "scan-business-data",
      "trigger": "点击刷新数据",
      "to": "refresh-business-data",
      "data_in": [
        "business-dashboard"
      ],
      "result_out": [
        "refresh-toast"
      ],
      "return_to": "scan-business-data",
      "return_payload": []
    }
  ],
  "data_handoffs": [
    {
      "handoff_id": "entry-feedback-handoff",
      "transition_id": "click-entry",
      "source_node": "use-workbench-entry",
      "target_node": "scan-business-data",
      "payload_content_refs": [
        "core-actions",
        "order-management",
        "customer-todo",
        "app-center"
      ],
      "reset_policy": "keep"
    },
    {
      "handoff_id": "refresh-feedback-handoff",
      "transition_id": "refresh-dashboard",
      "source_node": "refresh-business-data",
      "target_node": "scan-business-data",
      "payload_content_refs": [
        "business-dashboard"
      ],
      "reset_policy": "keep"
    }
  ],
  "prototype_boundaries": [
    {
      "node_id": "enter-workbench",
      "depth": "functional",
      "reason": "必须能从宿主工作台入口打开页面"
    },
    {
      "node_id": "scan-business-data",
      "depth": "simulated",
      "reason": "本轮不接后端，使用本地模拟数据表达经营状态"
    },
    {
      "node_id": "use-workbench-entry",
      "depth": "simulated",
      "reason": "已有路由可跳转，未展开子系统以明确 toast 反馈表示",
      "feedback": "功能入口已预留、功能接入中或已跳转"
    },
    {
      "node_id": "refresh-business-data",
      "depth": "simulated",
      "reason": "静态原型用 toast 表达准实时刷新",
      "feedback": "今日数据已更新"
    }
  ],
  "component_intent": [
    "经营数据卡片",
    "入口网格",
    "订单状态计数",
    "待办提醒",
    "应用分组列表",
    "toast 反馈",
    "已有路由跳转"
  ],
  "assumptions": [
    {
      "content": "本轮只做单页工作台首页，不展开完整子系统页面。",
      "impact_level": "low",
      "reversible": true
    },
    {
      "content": "数据使用本地模拟数据，不接真实后端。",
      "impact_level": "low",
      "reversible": true
    },
    {
      "content": "准实时通过更新时间文案和刷新 toast 表达。",
      "impact_level": "low",
      "reversible": true
    }
  ],
  "open_questions": [],
  "readiness": {
    "status": "ready-with-assumptions",
    "reason": "页面目标、入口、范围和原型深度已明确，剩余均为低风险可逆假设。"
  },
  "rule_sources": [
    {
      "source": "user-requirement",
      "supports": [
        "工作台包含经营数据、核心操作、订单、客户待办、应用中心和流量传播"
      ]
    },
    {
      "source": "AGENTS.md",
      "supports": [
        "场景落在 wego-app/scenes/{中文业务场景}",
        "使用 hash route 和 scene.js 注册"
      ]
    },
    {
      "source": "wego-product/SKILL.md",
      "supports": [
        "新任务使用 flows、surfaces、content_blocks、prototype_target 和 readiness"
      ]
    }
  ],
  "delivery_hint": "next-step: wego-design"
}
