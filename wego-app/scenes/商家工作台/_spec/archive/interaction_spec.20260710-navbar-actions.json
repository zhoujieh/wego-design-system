{
  "schemaVersion": 2,
  "task_type": "design-system-consumption",
  "scene_category": "other",
  "goal": "为商户提供移动端经营工作台，集中查看经营数据、处理订单待办、进入常用业务应用。",
  "business_goal": "商户在工作台首页快速查数据、开单、处理订单和进入运营应用。",
  "scope": {
    "included": [
      "单页工作台首页",
      "今日经营数据与昨日对比",
      "常用应用入口（最多2排，末尾含全部应用入口）",
      "销售订单状态计数",
      "客户流失预警待办",
      "完整应用中心二级页面（按业务分组展示全部应用）",
      "流量与传播明细"
    ],
    "excluded": [
      "发布商品、采购、销售开单、发货、直播、报表、营销等完整二级子系统",
      "真实后端数据接入",
      "自定义操作拖拽排序和持久化配置"
    ]
  },
  "actors": [
    {
      "id": "merchant-operator",
      "name": "商户经营者",
      "needs": [
        "快速了解今日经营表现",
        "快速进入日常高频业务",
        "及时处理订单和客户待办"
      ]
    }
  ],
  "interaction_mode": "view-only",
  "app_target": {
    "mode": "wego-app-scene",
    "app_root": "wego-app",
    "scene_folder": "wego-app/scenes/商家工作台",
    "runtime_entry": "scene.js",
    "route_mode": "hash"
  },
  "host_container": {
    "tab": "workspace",
    "entry_label": "工作台",
    "subentry_label": "",
    "leaf_level": 1,
    "entry_type": "host-tab",
    "needs_host_entry_surface": false
  },
  "prototype_target": {
    "app_root": "wego-app",
    "scenario_folder": "wego-app/scenes/商家工作台",
    "routes": [
      {
        "id": "workspace-merchant-workbench",
        "surface_ref": "merchant-workbench-main"
      },
      {
        "id": "workspace-app-center",
        "surface_ref": "app-center-page"
      }
    ]
  },
  "route_id": "workspace-merchant-workbench",
  "entry_points": [
    {
      "entry_id": "workspace-tab-entry",
      "tab": "workspace",
      "label": "工作台",
      "route_id": "workspace-merchant-workbench"
    }
  ],
  "flows": [
    {
      "flow_id": "view-workbench",
      "flow_type": "main",
      "entry_node": "enter-workbench",
      "steps": [
        "enter-workbench",
        "scan-business-data",
        "use-workbench-entry"
      ],
      "exit_condition": "商户完成查看数据或触发一个业务入口"
    },
    {
      "flow_id": "open-app-center",
      "flow_type": "branch",
      "entry_node": "use-workbench-entry",
      "steps": [
        "use-workbench-entry",
        "enter-app-center",
        "view-all-apps"
      ],
      "exit_condition": "商户查看全部应用列表或返回工作台"
    }
  ],
  "flow_nodes": [
    {
      "node_id": "enter-workbench",
      "purpose": "切换到工作台 Tab 后直接展示商家工作台首页",
      "surface_ref": "merchant-workbench-main",
      "inputs": [
        "workspace-tab-entry"
      ],
      "outputs": [
        "workbench-visible"
      ],
      "key_states": [
        "正常进入",
        "路由脚本加载失败时由宿主提示"
      ]
    },
    {
      "node_id": "scan-business-data",
      "purpose": "查看经营数据、订单待办、客户待办和流量传播",
      "surface_ref": "merchant-workbench-main",
      "inputs": [
        "business-dashboard",
        "order-management",
        "customer-todo",
        "traffic-analytics"
      ],
      "outputs": [
        "business-status-understood"
      ],
      "key_states": [
        "有数据"
      ]
    },
    {
      "node_id": "use-workbench-entry",
      "purpose": "点击常用应用入口或全部应用入口",
      "surface_ref": "merchant-workbench-main",
      "inputs": [
        "common-apps"
      ],
      "outputs": [
        "navigate-existing-route-or-stub-feedback",
        "open-app-center-page"
      ],
      "key_states": [
        "已有路由跳转",
        "未展开子系统显示占位反馈",
        "点击全部应用进入完整应用中心"
      ]
    },
    {
      "node_id": "enter-app-center",
      "purpose": "从工作台常用应用区点击全部应用进入完整应用中心页面",
      "surface_ref": "app-center-page",
      "inputs": [
        "app-center-full"
      ],
      "outputs": [
        "app-center-visible"
      ],
      "key_states": [
        "正常进入",
        "可返回工作台"
      ]
    },
    {
      "node_id": "view-all-apps",
      "purpose": "在完整应用中心页面按业务分组浏览全部应用入口",
      "surface_ref": "app-center-page",
      "inputs": [
        "app-center-full"
      ],
      "outputs": [
        "navigate-existing-route-or-stub-feedback"
      ],
      "key_states": [
        "已有路由跳转",
        "未展开应用显示占位反馈"
      ]
    }
  ],
  "surfaces": [
    {
      "surface_id": "merchant-workbench-main",
      "role": "primary-task-page",
      "carrier": "host-tab-page",
      "node_refs": [
        "enter-workbench",
        "scan-business-data",
        "use-workbench-entry"
      ],
      "content_refs": [
        "business-dashboard",
        "common-apps",
        "order-management",
        "customer-todo",
        "traffic-analytics"
      ],
      "interaction_mode": "view-only",
      "purpose": "承载商户经营概览和常用应用入口集合",
      "states": [
        "有数据",
        "入口占位反馈"
      ]
    },
    {
      "surface_id": "app-center-page",
      "role": "secondary-task-page",
      "carrier": "standalone-page",
      "node_refs": [
        "enter-app-center",
        "view-all-apps"
      ],
      "content_refs": [
        "app-center-full"
      ],
      "interaction_mode": "view-only",
      "purpose": "承载完整应用中心，按业务分组展示全部应用入口",
      "states": [
        "正常展示",
        "入口占位反馈"
      ]
    }
  ],
  "content_blocks": [
    {
      "content_id": "business-dashboard",
      "content": "经营数据看板，展示实收金额、销售单数、成交人数、访问人数、粉丝浏览量、员工业绩，并包含昨日对比和趋势。",
      "group": "核心经营数据看板",
      "interaction": "view",
      "editable": false,
      "default_state": "显示本地模拟今日数据",
      "key_states": [
        "显示昨日对比",
        "访问人数显示百分比涨跌"
      ]
    },
    {
      "content_id": "common-apps",
      "content": "常用应用入口网格，整合原核心操作与应用中心的高频入口，最多展示2排，末尾以全部应用入口收尾，点击进入完整应用中心页面。",
      "group": "常用应用",
      "interaction": "action",
      "editable": false,
      "default_state": "展示最多2排常用入口，最后一格为全部应用",
      "key_states": [
        "发布商品跳转已有发布路由",
        "查库存跳转已有库存路由",
        "采购入库可跳转仓库管理",
        "未展开入口显示明确反馈",
        "点击全部应用跳转完整应用中心页"
      ]
    },
    {
      "content_id": "order-management",
      "content": "销售订单状态计数，包含待收款、待发货、已挂起、待售后，并提供全部销售单和收益查看入口。",
      "group": "销售订单管理",
      "interaction": "action",
      "editable": false,
      "default_state": "显示本地模拟订单数量",
      "key_states": [
        "订单状态入口显示占位反馈",
        "销售单可跳转已有销售单相关入口时使用跳转，否则显示反馈"
      ]
    },
    {
      "content_id": "customer-todo",
      "content": "客户流失预警数量、回访提醒和营销触达入口。",
      "group": "客户智能待办",
      "interaction": "action",
      "editable": false,
      "default_state": "显示即将流失客户数量和跟进建议",
      "key_states": [
        "回访入口显示占位反馈",
        "营销触达显示占位反馈"
      ]
    },
    {
      "content_id": "app-center-full",
      "content": "完整应用中心，按店铺管理、数据报表、进销存管理、营销中心、财务与客户等业务分组展示全部应用入口。",
      "group": "完整应用中心",
      "interaction": "action",
      "editable": false,
      "default_state": "按业务分组展示全部入口",
      "key_states": [
        "已有路由可跳转",
        "未展开应用显示占位反馈"
      ]
    },
    {
      "content_id": "traffic-analytics",
      "content": "分享到聊天、分享到朋友圈、今日新增粉丝、全部粉丝的当日数据和昨日对比。",
      "group": "流量与传播明细",
      "interaction": "view",
      "editable": false,
      "default_state": "显示本地模拟传播与粉丝数据",
      "key_states": [
        "显示昨日对比",
        "无真实数据接入时保持模拟状态"
      ]
    }
  ],
  "states": [
    {
      "state_id": "normal",
      "description": "工作台展示完整模拟数据和所有入口"
    },
    {
      "state_id": "stub-feedback",
      "description": "未实现子系统入口点击后展示 toast 反馈"
    }
  ],
  "edge_cases": [
    "重复点击未展开入口时只显示当前 toast，不产生重复页面",
    "已有路由跳转由宿主在 phone-screen 内打开",
    "常用应用入口数量固定为最多2排，超出部分收纳到全部应用",
    "全部应用页面支持返回工作台"
  ],
  "transitions": [
    {
      "transition_id": "open-workbench-route",
      "from": "enter-workbench",
      "trigger": "点击底部工作台 Tab 或访问 hash route",
      "to": "scan-business-data",
      "data_in": [
        "workspace-tab-entry"
      ],
      "result_out": [
        "workbench-visible"
      ],
      "return_to": "",
      "return_payload": []
    },
    {
      "transition_id": "click-common-app",
      "from": "scan-business-data",
      "trigger": "点击常用应用入口",
      "to": "use-workbench-entry",
      "data_in": [
        "common-apps"
      ],
      "result_out": [
        "navigate-existing-route-or-stub-feedback"
      ],
      "return_to": "scan-business-data",
      "return_payload": []
    },
    {
      "transition_id": "open-all-apps",
      "from": "use-workbench-entry",
      "trigger": "点击常用应用区的全部应用入口",
      "to": "enter-app-center",
      "data_in": [
        "app-center-full"
      ],
      "result_out": [
        "app-center-visible"
      ],
      "return_to": "use-workbench-entry",
      "return_payload": []
    },
    {
      "transition_id": "click-app-center-app",
      "from": "enter-app-center",
      "trigger": "点击完整应用中心内的应用入口",
      "to": "view-all-apps",
      "data_in": [
        "app-center-full"
      ],
      "result_out": [
        "navigate-existing-route-or-stub-feedback"
      ],
      "return_to": "enter-app-center",
      "return_payload": []
    }
  ],
  "data_handoffs": [
    {
      "handoff_id": "common-app-feedback-handoff",
      "transition_id": "click-common-app",
      "source_node": "use-workbench-entry",
      "target_node": "scan-business-data",
      "payload_content_refs": [
        "common-apps"
      ],
      "reset_policy": "keep"
    },
    {
      "handoff_id": "app-center-handoff",
      "transition_id": "open-all-apps",
      "source_node": "use-workbench-entry",
      "target_node": "enter-app-center",
      "payload_content_refs": [
        "app-center-full"
      ],
      "reset_policy": "keep"
    },
    {
      "handoff_id": "app-center-app-feedback-handoff",
      "transition_id": "click-app-center-app",
      "source_node": "view-all-apps",
      "target_node": "enter-app-center",
      "payload_content_refs": [
        "app-center-full"
      ],
      "reset_policy": "keep"
    }
  ],
  "prototype_boundaries": [
    {
      "node_id": "enter-workbench",
      "depth": "functional",
      "reason": "必须能从底部工作台 Tab 直接进入页面"
    },
    {
      "node_id": "scan-business-data",
      "depth": "simulated",
      "reason": "本轮不接后端，使用本地模拟数据表达经营状态"
    },
    {
      "node_id": "use-workbench-entry",
      "depth": "simulated",
      "reason": "已有路由可跳转，未展开子系统以明确 toast 反馈表示；全部应用可跳转至完整应用中心页",
      "feedback": "功能入口已预留、功能接入中或已跳转"
    },
    {
      "node_id": "enter-app-center",
      "depth": "functional",
      "reason": "完整应用中心是独立二级页面，需要可进入和返回"
    },
    {
      "node_id": "view-all-apps",
      "depth": "simulated",
      "reason": "已有路由可跳转，未展开应用以明确 toast 反馈表示",
      "feedback": "功能入口已预留、功能接入中或已跳转"
    }
  ],
  "component_intent": [
    "经营数据卡片",
    "入口网格（常用应用，最多2排，末尾全部应用）",
    "订单状态计数",
    "待办提醒",
    "应用分组列表（完整应用中心页）",
    "toast 反馈",
    "已有路由跳转"
  ],
  "assumptions": [
    {
      "content": "本轮只做工作台首页和完整应用中心页，不展开完整子系统页面。",
      "impact_level": "low",
      "reversible": true
    },
    {
      "content": "数据使用本地模拟数据，不接真实后端。",
      "impact_level": "low",
      "reversible": true
    },
    {
      "content": "常用应用默认展示2排共8个入口，最后一格替换为全部应用。",
      "impact_level": "low",
      "reversible": true
    }
  ],
  "open_questions": [],
  "readiness": {
    "status": "ready-with-assumptions",
    "reason": "页面目标、入口、范围和原型深度已明确，剩余均为低风险可逆假设。"
  },
  "rule_sources": [
    {
      "source": "user-requirement",
      "supports": [
        "工作台包含经营数据、常用应用入口、订单、客户待办、流量传播",
        "核心操作更名为常用应用，与应用中心合并",
        "常用应用最多2排，末尾有全部应用入口跳转完整应用中心页",
        "去掉 navbar 刷新图标"
      ]
    },
    {
      "source": "AGENTS.md",
      "supports": [
        "场景落在 wego-app/scenes/{中文业务场景}",
        "使用 hash route 和 scene.js 注册"
      ]
    },
    {
      "source": "wego-product/SKILL.md",
      "supports": [
        "新任务使用 flows、surfaces、content_blocks、prototype_target 和 readiness"
      ]
    }
  ],
  "delivery_hint": "next-step: wego-design"
}
