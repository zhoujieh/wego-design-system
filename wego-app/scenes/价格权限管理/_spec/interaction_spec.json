{
  "task_type": "design-system-consumption",
  "scene_category": "biz-rule-config",
  "goal": "为店铺配置每个价格类型的可见权限：默认提供拿货价、售价、批发价、代发价、打包价五种价格类型，每个价格类型可设置为公开、私密、部分可见或不给谁看；部分可见与不给谁看均展开粉丝分组多选，页面级统一保存。",
  "scope": {
    "included": [
      "『我的』App 中心 grid 中的『价格管理』一级入口",
      "价格类型列表页：展示五种默认价格类型及当前权限摘要，点击进入权限设置",
      "权限设置页：权限类型四选一、部分可见/不给谁看展开粉丝分组多选、页面级保存"
    ],
    "excluded": [
      "新增或删除价格类型",
      "新增或编辑粉丝分组",
      "粉丝分组管理页",
      "价格数值本身的编辑"
    ]
  },
  "actors": [
    { "id": "shop-owner", "role": "店主", "purpose": "为每个价格类型配置可见权限，控制不同粉丝分组看到的价格" }
  ],
  "entry_points": [
    {
      "id": "my-app-center-grid",
      "carrier": "host-grid-entry",
      "description": "『我的』App 中心 grid 中的『价格管理』一级入口，点击 push 进入价格类型列表页"
    }
  ],
  "flows": [
    {
      "flow_id": "configure-permission",
      "flow_type": "main",
      "entry_node": "enter-price-list",
      "steps": ["enter-price-list", "select-price-type", "edit-permission", "save-permission"],
      "exit_condition": "返回『我的』App 中心或切换到其他 Tab"
    },
    {
      "flow_id": "cancel-edit",
      "flow_type": "branch",
      "entry_node": "edit-permission",
      "steps": ["edit-permission", "cancel-edit"],
      "exit_condition": "返回价格类型列表页且不保留本次编辑"
    },
    {
      "flow_id": "save-without-groups",
      "flow_type": "exception",
      "entry_node": "save-permission",
      "steps": ["save-permission", "block-save"],
      "exit_condition": "提示用户至少选择一个粉丝分组后停留在权限设置页"
    }
  ],
  "flow_nodes": [
    {
      "node_id": "enter-price-list",
      "purpose": "从『我的』App 中心 grid 进入价格管理列表页，展示全部价格类型及当前权限摘要",
      "surface_ref": "price-type-list",
      "inputs": [],
      "outputs": ["价格类型列表及权限摘要"],
      "key_states": ["已有配置态", "默认配置态"]
    },
    {
      "node_id": "select-price-type",
      "purpose": "选择某个价格类型进入其权限设置页",
      "surface_ref": "price-type-list",
      "inputs": ["目标价格类型"],
      "outputs": ["进入权限设置页"],
      "key_states": ["点击进入"]
    },
    {
      "node_id": "edit-permission",
      "purpose": "编辑单个价格类型的权限类型，并在部分可见/不给谁看时选择粉丝分组",
      "surface_ref": "price-permission-edit",
      "inputs": ["当前价格类型", "当前权限配置"],
      "outputs": ["编辑中的权限配置"],
      "key_states": ["编辑态", "部分可见已展开", "不给谁看已展开", "未选分组"]
    },
    {
      "node_id": "save-permission",
      "purpose": "保存当前价格类型的权限配置并返回列表页",
      "surface_ref": "price-permission-edit",
      "inputs": ["编辑中的权限配置"],
      "outputs": ["保存后的权限配置", "列表页权限摘要回填"],
      "key_states": ["保存成功", "保存被阻止"]
    },
    {
      "node_id": "cancel-edit",
      "purpose": "放弃本次编辑返回列表页",
      "surface_ref": "price-permission-edit",
      "inputs": [],
      "outputs": [],
      "key_states": ["取消返回"]
    },
    {
      "node_id": "block-save",
      "purpose": "部分可见/不给谁看未选分组时阻止保存并提示",
      "surface_ref": "price-permission-edit",
      "inputs": ["未选分组的编辑态"],
      "outputs": ["提示信息"],
      "key_states": ["阻止保存"]
    }
  ],
  "surfaces": [
    {
      "surface_id": "host-entry",
      "role": "host-entry",
      "carrier": "host-grid-entry",
      "node_refs": [],
      "content_refs": ["price-entry"],
      "interaction_mode": "select",
      "purpose": "作为『我的』App 中心 grid 的一级入口承载打开动作；点击 push 进入价格类型列表页；保存后承接权限配置结果的状态回填",
      "states": ["默认", "已配置摘要回填"]
    },
    {
      "surface_id": "price-type-list",
      "role": "primary-task-page",
      "carrier": "standalone-page",
      "node_refs": ["enter-price-list", "select-price-type"],
      "content_refs": ["price-list-nav", "price-type-list-content"],
      "interaction_mode": "select",
      "purpose": "展示全部价格类型入口及当前权限摘要；点击进入对应价格类型的权限设置页；承接从权限设置页返回后的权限摘要回填",
      "states": ["已有配置态", "默认配置态"]
    },
    {
      "surface_id": "price-permission-edit",
      "role": "primary-task-page",
      "carrier": "full-screen-modal",
      "node_refs": ["edit-permission", "save-permission", "cancel-edit", "block-save"],
      "content_refs": ["price-edit-nav", "perm-type-options", "partial-fan-groups", "exclude-fan-groups"],
      "interaction_mode": "edit-then-save",
      "purpose": "承接单个价格类型的权限配置：四选一权限类型，部分可见/不给谁看展开粉丝分组多选，页面级保存收口",
      "states": ["编辑态", "部分可见已展开", "不给谁看已展开", "未选分组阻止保存", "保存成功"]
    }
  ],
  "content_blocks": [
    {
