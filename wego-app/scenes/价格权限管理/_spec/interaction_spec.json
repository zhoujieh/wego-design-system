    {
      "content_id": "exclude-fan-groups",
      "content": "权限类型为『不给谁看』时展开的粉丝分组多选",
      "group": "权限设置页",
      "interaction": "select",
      "editable": true,
      "key_states": ["展开", "未选分组", "已选若干分组"]
    }
