  "transitions": [
    {
      "transition_id": "enter-to-select",
      "from": "enter-price-list",
      "trigger": "点击某个价格类型行",
      "to": "select-price-type",
      "data_in": ["目标价格类型"],
      "result_out": ["进入权限设置页"]
