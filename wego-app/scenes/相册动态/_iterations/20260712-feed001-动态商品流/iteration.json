  "prototype_brief": {
    "goal": "让用户在微购相册中连续浏览店主发布的商品动态，每条动态稳定呈现发布者、发布时间、商品内容、商品图片与相关产品信息，并支持进入产品详情或执行必要操作。",
    "included": [
      "动态商品流浏览场景：连续浏览店主发布的商品动态",
      "每条动态稳定呈现发布者、发布时间、商品内容、商品图片、相关产品信息",
      "兼容只有产品信息与同时含文字两种动态形态",
      "兼容文字为空、图片数量不同、产品信息较长时的稳定展示",
      "进入产品详情入口",
      "必要操作入口：一键转发（核心操作）、复制文案、分享、收藏、下载图片、搜索、编辑、复制动态、图片点击看大图"
    ],
    "excluded": [
      "发布动态（用户未提及）",
      "评论、点赞等社交互动（用户未提及）",
      "必要操作的具体功能实现（本轮只放入口，不下钻）",
      "真实后端接口与持久化（原型范围）"
    ],
    "entry_points": [
      "动态主 tab：作为底部导航「动态」tab 的内容，打开 App 即默认进入"
    ],
    "critical_paths": [
      "进入动态流 → 连续浏览动态 → 进入产品详情",
      "进入动态流 → 连续浏览动态 → 执行必要操作"
    ],
    "prototype_boundaries": [
      "动态商品流浏览场景 functional：可连续浏览、动态状态真实可操作",
      "产品详情 simulated：用本地模拟数据展示基本产品信息，不实现完整电商详情能力",
      "必要操作入口 stub：本轮只呈现入口与明确反馈，不下钻具体功能实现"
    ],
    "assumptions": [
      {
        "item": "原型使用 wego-app/lib/image/clothing 下已有服装图片作为商品图占位",
        "impact_level": "low",
        "reversible": true
      }
    ],
    "open_questions": []
  },
  "prototype_design": {
    "surface_decisions": [
      {
        "surface_id": "feed-host-tab",
        "role": "host-entry",
        "matched_blueprint": "continuous-content-feed-page",
        "match_status": "fallback",
        "presentation": "host-tab",
        "covers_tab_bar": true,
        "layout_contract": {
          "page_edge_mode": "M0",
          "page_edge_mode_reason": "命中 continuous-content-feed-page blueprint 的默认期望；连续内容流优先保证扫读效率与信息密度，不套常规卡片页 M16；动态卡片横向边距由卡片自身 padding 承担",
          "media_priority": "supporting",
          "media_priority_reason": "单条动态同时承载发布者、时间、正文、商品摘要和操作，媒体只作辅助判断，不主导首屏高度；商品图区让位于文字与对象摘要",
          "first_screen_content_rule": "首屏只承接已确认业务对象：发布者、时间、正文、商品图、商品摘要、操作入口；禁止默认总览、导览、刷新、原型和评审说明",
          "optional_content_policy": "动态正文为空时折叠正文结构；商品图数量为 0 时不渲染图区；商品摘要字段缺失时不补未填写/暂无；只有缺失本身是已确认业务状态时才显示状态文案"
        },
        "component_mapping": [
          {
            "slot": "page-top-search",
            "slug": "search",
            "consumption_mode": "stable-variant",
            "variant": "searchbox 基础三段式（左图标+中输入+右内部动作），sticky 吸顶",
            "reason": "命中 search 组件 semanticTypeCandidates.searchbox；简报必要操作包含搜索，搜索语义必须消费 search 组件不得用 input 临时拼"
          },
          {
            "slot": "feed-item-author",
            "slug": "avatar",
            "consumption_mode": "stable-variant",
            "variant": "type=image size=40",
            "reason": "avatar 40 用于常规身份位，承载发布者头像"
          },
          {
            "slot": "feed-item-body",
            "slug": "card",
            "consumption_mode": "free-composition",
            "variant": "surface=none，作为单条动态的内容分组容器，不自带 padding",
            "reason": "card 默认只承担内容分组语义；页面级留白由业务作用域样式承担，不扩展成业务卡片"
          },
          {
            "slot": "feed-item-media",
            "slug": "image",
            "consumption_mode": "stable-variant",
            "variant": "fit=cover, radius=rounded-md, interaction=clickable",
