          },
          {
            "slot": "feed-item-product-price",
            "slug": "metric",
            "consumption_mode": "stable-variant",
            "variant": "size=16 或 20, theme=marketing",
            "reason": "商品价格必须消费 metric 组件，不得回退成自定义 price 类；营销橙主题用于商品价格"
          },
          {
            "slot": "feed-item-product-tags",
            "slug": "tag",
            "consumption_mode": "stable-variant",
            "variant": "size=20 theme=gray display-only 或 size=24 theme=brand entry",
            "reason": "商品状态/业务标签使用 tag；20 用于纯展示，24 用于入口跳转"
          },
          {
            "slot": "feed-item-product-entry",
            "slug": "link",
            "consumption_mode": "stable-variant",
            "variant": "mode=standalone size=14",
            "reason": "进入产品详情入口使用 link standalone，不用 button 强动作；standalone 提供紧凑热区和按压态"
          },
          {
            "slot": "feed-item-primary-action",
            "slug": "button",
            "consumption_mode": "stable-variant",
            "variant": "weak 或 medium 尺寸，不用 strong",
            "reason": "一键转发是核心操作但属于列表项内操作，按 blueprint 约束重复列表项内禁止 strong 主按钮；strong 只保留给页面级唯一主动作"
          },
          {
            "slot": "feed-item-more-actions",
            "slug": "actionsheet",
            "consumption_mode": "stable-variant",
            "variant": "mode=action, header=text, item=text 或 icon",
            "reason": "3+ 并列操作（复制文案/分享/收藏/下载图片/搜索/编辑/复制动态）收进 actionsheet；actionsheet 是 sheet primitive 的具体组件实现"
          },
          {
            "slot": "feed-feedback",
            "slug": "toast",
            "consumption_mode": "stable-variant",
            "variant": "default 或 guide",
            "reason": "必要操作 stub 反馈使用 toast；dialog 用于需要二次确认的危险操作"
          }
