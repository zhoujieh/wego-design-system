            ]
          }
        ],
        "layout_contract": {
          "page_edge_mode": "M0",
          "page_edge_mode_reason": "连续内容流主任务，复杂信息密度高，按 continuous-content-feed-page 默认期望选择通栏 M0；动态卡片自身用 surface 白底承担表面区分，不在页面层再加 16px 横向 padding 压缩宽度",
          "media_priority": "supporting",
          "media_priority_reason": "动态首屏要让位于发布者识别、时间、正文与产品摘要；图片只作辅助判断，单条内容首屏高度由文字与对象摘要决定，不由图片主导",
          "first_screen_content_rule": "首屏只承接已确认业务对象（动态）、状态（发布者/时间）、动作（一键转发/更多/图片点击）和任务直接相关摘要（产品信息卡）；禁止导览、刷新说明、原型说明",
          "optional_content_policy": "可选正文为空时折叠正文结构；图片数量为 0 时折叠图片区；产品信息较长时由产品卡内部省略截断，不在卡片外补未填写或暂无文案"
        },
        "component_mapping": [
          {
            "applies_to": [
              "feed-navbar"
            ],
            "component": "navbar",
            "consumption_mode": "stable-variant",
            "variant": {
              "leftControl": "none",
              "titleAlignment": "left-wide",
              "actions": "icon",
              "rightActionType": "icon",
              "position": "sticky"
            },
            "constraint": "host-tab 直挂页面，左侧无返回；右侧搜索为图标+文字组合，不使用纯单图标",
            "rule_sources": [
              "components/navbar.json.representativeVariants",
              "components/navbar.json.usageHints"
            ]
          },
          {
            "applies_to": [
              "feed-list"
            ],
            "component": "avatar",
            "consumption_mode": "stable-variant",
            "variant": {
              "type": "image",
              "size": "40"
            },
            "constraint": "每条动态发布者头像使用 40 尺寸图片头像；无头像数据时使用 assets/image/avatar-defult.png",
            "rule_sources": [
              "components/avatar.json.representativeVariants",
              "components/avatar.json.assets"
            ]
          },
          {
            "applies_to": [
              "feed-list"
            ],
            "component": "image",
            "consumption_mode": "composition-constraint",
            "variant": {
              "fit": "cover",
              "radius": "rounded-md",
              "interaction": "clickable"
            },
            "constraint": "动态图片网格使用 wg-image--rounded-md 圆角与 wg-image--clickable 可点击态；1 张图用单图宽幅，2-4 张用 2 列网格，5-9 张用 3 列网格（最后一格如不足 9 张保留空位不补占位）；图片点击触发 image-viewer surface",
            "rule_sources": [
              "components/image.json.representativeVariants",
              "components/image.json.domAnatomy"
            ]
          },
          {
            "applies_to": [
              "feed-list"
            ],
            "component": "card",
            "consumption_mode": "free-composition",
            "variant": {
              "base": "auto",
              "surface": "surface"
            },
            "constraint": "每条动态使用 card--surface 白底圆角承载，card__content 内部由业务作用域 class 编排发布者行、正文、图片网格、产品摘要、操作行；不在基础 card 上发明 .card__media 等业务子元素类",
            "rule_sources": [
              "components/card.json.structurePatterns",
              "components/card.json.doNotInvent"
            ]
          },
          {
            "applies_to": [
              "feed-list"
            ],
            "component": "metric",
            "consumption_mode": "stable-variant",
            "variant": {
              "size": "16",
              "theme": "marketing"
            },
            "constraint": "产品摘要中的价格使用 metric--16 marketing 主题，强制两位小数；区间价用 ~ 连接仅开头用货币符号",
            "rule_sources": [
              "components/metric.json.representativeVariants",
              "components/metric.json.accessibility.contentRule"
            ]
          },
          {
            "applies_to": [
              "feed-list"
            ],
            "component": "tag",
            "consumption_mode": "stable-variant",
            "variant": {
              "size": "20",
              "theme": "promotion",
              "affordance": "display-only"
            },
            "constraint": "产品摘要上的促销标签（如秒杀、拼团）使用 tag--20 promotion display-only；宿主白底背景用 tag--white 主题保证对比",
            "rule_sources": [
              "components/tag.json.representativeVariants",
              "components/tag.json.usageHints"
            ]
          },
          {
            "applies_to": [
              "feed-list"
            ],
            "component": "button",
            "consumption_mode": "stable-variant",
            "variant": {
              "emphasis": "weak",
              "size": "sm",
              "iconMode": "leading-icon"
            },
            "constraint": "每条动态操作行外露「一键转发」weak sm 带前置 icon-fasongjiantou；同页不出现 strong 主按钮，列表项内不堆叠多个同级强按钮",
            "rule_sources": [
              "components/button.json.representativeVariants",
              "components/button.json.doNotInvent"
            ]
          },
          {
            "applies_to": [
              "feed-list"
            ],
            "component": "link",
            "consumption_mode": "stable-variant",
            "variant": {
              "mode": "standalone",
              "size": "14",
              "state": "default"
            },
            "constraint": "操作行右侧「更多」使用 link standalone 14px，触发 actionsheet；不用业务作用域自定义类模拟 link 视觉",
            "rule_sources": [
              "components/link.json.representativeVariants",
              "library-consumption.json.componentConsumptionNotes"
            ]
          },
          {
            "applies_to": [
              "feed-list"
            ],
            "component": "actionsheet",
            "consumption_mode": "stable-variant",
            "variant": {
              "mode": "action",
              "header": "text",
              "item": "text"
            },
            "constraint": "「更多」触发 actionsheet action 模式，承载复制文案、分享、收藏、下载图片、编辑、复制动态 6 项；不超过 8 项；点击任一项后关闭并 toast 反馈",
            "rule_sources": [
              "components/actionsheet.json.representativeVariants",
              "components/actionsheet.json.doNotInvent",
              "uikit-plan.json.fallbackPageBlueprints[continuous-content-feed-page].layoutRules"
            ]
          },
          {
            "applies_to": [
              "feed-list"
            ],
            "component": "toast",
            "consumption_mode": "stable-variant",
            "variant": {
              "variant": "default",
              "iconMode": "none",
              "actionMode": "none"
            },
            "constraint": "stub 操作（复制文案、分享、收藏、下载图片、编辑、复制动态、搜索）点击后用默认 toast 给出明确反馈，不持久化、不叠加",
            "rule_sources": [
              "components/toast.json.representativeVariants",
              "components/toast.json.doNotInvent"
            ]
          }
        ],
        "implementation_constraints": [
          "动态卡片结构按发布者行（avatar + 昵称 + 时间）→ 正文（可选，空则折叠）→ 图片网格（可选，0 张则折叠）→ 产品摘要卡（可点击进入 product-detail）→ 操作行（一键转发 + 更多）顺序编排",
          "产品摘要卡点击为下钻入口，不加额外「查看详情」按钮，由卡片自身点击承载",
          "图片点击为下钻入口，触发 image-viewer surface 显示大图，不额外加「看大图」按钮",
          "「一键转发」是 functional 级别核心操作，点击后真实切换为「已转发」状态并在操作行内体现，不依赖后端",
          "actionsheet 6 项 stub 操作点击后关闭浮层并 toast 明确反馈，本轮不下钻具体功能实现",
          "navbar 右侧搜索入口点击触发 toast stub 反馈，本轮不实现搜索结果层",
          "动态流由本地模拟数据驱动，至少 6 条动态覆盖：只有产品信息形态、同时含文字形态、文字为空、单图、多图、产品信息较长",
          "页面背景 data-bg=page，动态卡片白底承担表面区分；navbar 背景跟随 data-bg=page 灰底",
          "页面底部无固定操作栏，可滚动内容容器底部补 calc(40px + var(--safe-area-bottom)) 避开 bottom-nav 安全区"
        ],
        "rule_sources_used": [
