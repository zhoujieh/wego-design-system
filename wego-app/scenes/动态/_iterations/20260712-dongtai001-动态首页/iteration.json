  "prototype_brief": {
    "goal": "让用户在动态主 tab 浏览已关注店主发布的图文动态与上新商品，发现感兴趣的内容与店主，参考淘宝首页关注 tab 的内容组织方式",
    "included": [
      "按内容分类切换浏览动态（关注、推荐、视频）",
      "已关注店主的快捷入口，可进入店主主页",
      "店主发布的图文动态，包含纯图文动态和带关联商品的动态两种内容形式",
      "动态内容按发布时间倒序排列，关注分类只展示已关注店主的动态",
      "动态关联商品的展示与点击进入商品详情",
      "动态的点赞、评论、转发互动",
      "已关注店主有新动态时的未读标记",
      "搜索店主或商品入口"
    ],
    "excluded": [
      "视频播放与直播详情",
      "私信与聊天会话",
      "动态页顶部消息入口（消息复用底部消息 tab，不在动态页内放置消息入口）",
      "后端真实数据接口与登录态校验",
      "支付与下单流程",
      "店主主页与商品详情的完整实现",
      "动态发布功能",
      "推荐分类的个性化推荐算法（仅本地模拟若干条动态）"
    ],
    "entry_points": [
      "动态主 tab（应用启动默认入口）"
    ],
    "critical_paths": [
      "进入动态主 tab → 浏览已关注店主发布的动态",
      "浏览动态 → 查看动态内关联商品 → 进入商品详情",
      "浏览动态 → 进入发布该动态的店主主页",
      "浏览动态 → 点赞 / 评论 / 转发",
      "通过已关注店主快捷入口 → 进入店主主页"
    ],
    "prototype_boundaries": [
      "内容分类切换：functional（本地切换状态，三分类固定）",
      "已关注店主快捷入口：functional（点击进入店主主页 stub，含未读标记）",
      "图文动态浏览：functional（本地模拟数据填充动态流，按发布时间倒序）",
      "动态内关联商品点击：functional（跳转商品详情 stub）",
      "点赞：functional（本地状态切换与计数）",
      "评论：simulated（本地模拟评论列表与发布反馈）",
      "转发：simulated（本地模拟转发成功反馈）",
      "搜索：stub（提供入口与占位反馈，不实现结果）",
      "店主主页：stub（独立 route，占位反馈）",
      "商品详情：stub（独立 route，占位反馈）"
    ],
    "assumptions": [
      {
        "description": "假设用户默认已登录",
        "impact_level": "low",
        "reversible": true
      },
      {
        "description": "假设已关注若干店主，用本地模拟数据填充关注列表与动态流",
        "impact_level": "low",
        "reversible": true
      },
      {
        "description": "内容分类固定为关注、推荐、视频三类，后续迭代再扩展",
        "impact_level": "low",
        "reversible": true
      },
      {
        "description": "推荐分类用本地模拟数据展示若干条动态，不实现真实推荐算法",
        "impact_level": "low",
        "reversible": true
      }
    ],
    "open_questions": [
      {
        "description": "是否需要支持未登录访客浏览动态？",
        "impact_level": "local",
        "blocking": false
      }
    ]
