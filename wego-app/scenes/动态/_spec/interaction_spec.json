      "content": "底部说明文案：帮卖佣金仅自己可见，可放心分享",
      "group": "加价卖弹窗",
      "interaction": "view",
      "editable": false,
      "key_states": ["默认"]
    },
    {
      "content_id": "resale-submit-action",
      "content": "底部主按钮'帮卖并分享'，点击后保存帮卖售价、生成帮卖商品、生成分享内容并进入分享流程；非法输入时按钮不可点击",
      "group": "加价卖弹窗",
      "interaction": "action",
      "editable": false,
      "key_states": ["可点击", "禁用(非法输入)", "提交反馈"]
    }
  ],
  "transitions": [
    {
      "transition_id": "enter-to-browse",
      "from": "enter-feed",
      "trigger": "动态加载完成",
      "to": "browse-list",
      "data_in": [],
      "result_out": ["动态列表数据"]
    },
    {
      "transition_id": "browse-to-filter",
      "from": "browse-list",
      "trigger": "切换筛选 Tab",
      "to": "filter-feed",
      "data_in": ["filter-tabs 选择"],
      "result_out": ["筛选后列表"]
    },
    {
      "transition_id": "browse-to-operate",
      "from": "browse-list",
      "trigger": "点击单条动态操作按钮",
      "to": "operate-item",
      "data_in": ["目标动态"],
      "result_out": ["操作结果"]
    },
    {
      "transition_id": "browse-to-resale",
      "from": "browse-list",
      "trigger": "点击动态卡片操作行帮卖按钮",
      "to": "trigger-resale",
      "data_in": ["目标动态", "商品售价"],
      "result_out": ["打开加价卖弹窗"]
    },
    {
      "transition_id": "resale-to-configure",
      "from": "trigger-resale",
      "trigger": "弹窗打开",
