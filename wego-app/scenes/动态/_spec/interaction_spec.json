      "result_out": ["默认售价", "初始收益"]
    },
    {
      "transition_id": "configure-to-submit",
      "from": "configure-resale-price",
      "trigger": "点击帮卖并分享",
      "to": "submit-resale",
      "data_in": ["我的售价"],
      "result_out": ["帮卖商品", "分享内容"]
    }
  ],
  "data_handoffs": [
    {
      "handoff_id": "feed-to-resale-sheet",
      "transition_ref": "browse-to-resale",
      "source_node": "browse-list",
      "target_node": "configure-resale-price",
      "payload_content_refs": ["feed-item-summary"],
      "reset_policy": "reset"
    }
  ],
  "prototype_boundaries": [
