{
  "task_type": "design-system-consumption",
  "scene_category": "list",
  "goal": "让用户在动态 Tab 浏览产品动态流，快速查看、筛选和操作自己的产品动态；并对产品发起帮卖（加价转卖），设置帮卖售价后生成帮卖商品并进入分享流程",
  "scope": {
    "included": [
      "动态流列表页：工具栏（搜索入口 + 发布入口）",
      "筛选 Tab（全部 / 上新）",
      "动态卡片列表（发布者身份、动态标题、产品九宫格图、产品摘要、产品信息、操作按钮、帮卖按钮）",
      "加价卖半弹窗：标题+帮助入口、我的售价输入、实时收益、快捷加价、底部说明、帮卖并分享主按钮"
    ],
    "excluded": [
      "发布产品完整流程（已有独立场景）",
      "产品详情页",
      "搜索结果页",
      "图片搜索识别流程",
      "真实分享流程（本次 stub 提示）",
      "加价卖说明详情页（外链跳转）",
      "帮卖商品后续管理"
    ]
  },
  "actors": [
    { "id": "shop-owner", "role": "店主", "purpose": "浏览和操作自己的产品动态，发起帮卖" }
  ],
  "entry_points": [
    {
      "id": "dongtai-tab",
      "carrier": "host-fixed-tab",
      "description": "宿主底部第一个固定 Tab，点击切换到动态页"
    },
    {
      "id": "resale-entry",
      "carrier": "inline-action",
      "description": "动态卡片操作行最右侧的帮卖按钮，点击拉起加价卖半弹窗"
    }
  ],
  "flows": [
    {
      "flow_id": "browse-feed",
      "flow_type": "main",
      "entry_node": "enter-feed",
      "steps": ["enter-feed", "browse-list", "filter-feed", "operate-item"],
      "exit_condition": "切换到其他 Tab"
    },
    {
      "flow_id": "resale-product",
      "flow_type": "main",
      "entry_node": "trigger-resale",
      "steps": ["trigger-resale", "configure-resale-price", "submit-resale"],
      "exit_condition": "关闭弹窗或完成帮卖分享"
    }
  ],
  "flow_nodes": [
    {
      "node_id": "enter-feed",
      "purpose": "进入动态 Tab，展示动态流",
      "surface_ref": "dynamic-feed-main",
      "inputs": [],
      "outputs": ["动态列表数据"],
      "key_states": ["已有数据态", "空态", "加载态"]
    },
    {
      "node_id": "browse-list",
      "purpose": "浏览动态卡片列表",
      "surface_ref": "dynamic-feed-main",
      "inputs": ["动态列表数据"],
      "outputs": [],
      "key_states": ["滚动浏览"]
    },
    {
      "node_id": "filter-feed",
      "purpose": "按全部/上新筛选动态",
      "surface_ref": "dynamic-feed-main",
      "inputs": ["筛选 Tab 选择"],
      "outputs": ["筛选后列表"],
      "key_states": ["全部", "上新"]
    },
    {
      "node_id": "operate-item",
      "purpose": "对单条动态执行操作（删除/下架/刷新/置顶/编辑）",
      "surface_ref": "dynamic-feed-main",
      "inputs": ["目标动态"],
      "outputs": ["操作结果"],
      "key_states": ["操作前", "操作反馈"]
    },
    {
      "node_id": "trigger-resale",
      "purpose": "点击动态卡片操作行的帮卖按钮，拉起加价卖半弹窗",
      "surface_ref": "dynamic-feed-main",
      "inputs": ["目标动态", "商品售价"],
      "outputs": ["打开加价卖弹窗"],
      "key_states": ["弹窗未打开", "弹窗打开"]
    },
    {
      "node_id": "configure-resale-price",
      "purpose": "在加价卖弹窗内设置我的售价，支持手动输入和快捷加价，实时计算收益",
      "surface_ref": "resale-sheet",
      "inputs": ["商品售价", "推荐加价比例"],
      "outputs": ["我的售价", "收益"],
      "key_states": ["初始态(默认推荐价)", "输入中(实时更新)", "非法输入(错误状态)"]
    },
    {
      "node_id": "submit-resale",
      "purpose": "点击帮卖并分享，保存帮卖售价、生成帮卖商品和分享内容并进入分享流程",
      "surface_ref": "resale-sheet",
      "inputs": ["我的售价"],
      "outputs": ["帮卖商品", "分享内容"],
      "key_states": ["提交前", "提交反馈"]
    }
  ],
  "surfaces": [
    {
      "surface_id": "dynamic-feed-main",
      "role": "primary-task-page",
      "carrier": "host-fixed-tab",
      "node_refs": ["enter-feed", "browse-list", "filter-feed", "operate-item", "trigger-resale"],
      "content_refs": [
        "search-entry",
        "publish-entry",
        "filter-tabs",
        "feed-item-identity",
        "feed-item-title",
        "feed-item-gallery",
        "feed-item-summary",
        "feed-item-info",
        "feed-item-actions",
        "feed-item-resale-action"
      ],
      "interaction_mode": "instant-apply",
      "purpose": "动态 Tab 主页面，承载动态流浏览、筛选、单条操作和帮卖入口",
      "states": ["已有数据态", "空态", "加载态"]
    },
    {
      "surface_id": "resale-sheet",
      "role": "secondary-task-page",
      "carrier": "sheet",
      "node_refs": ["configure-resale-price", "submit-resale"],
      "content_refs": [
        "resale-sheet-header",
        "resale-price-input",
        "resale-earnings",
        "resale-quick-markup",
        "resale-bottom-note",
        "resale-submit-action"
      ],
      "interaction_mode": "edit-then-save",
      "purpose": "加价卖半弹窗，设置帮卖售价并实时查看收益，确认后生成帮卖商品并进入分享流程",
      "states": ["初始态", "输入中", "非法输入", "关闭不保存"]
    }
  ],
  "content_blocks": [
    {
      "content_id": "search-entry",
      "content": "搜索入口，支持按标题/搜索码/货号搜索，以及图片搜索",
      "group": "工具栏",
      "interaction": "action",
      "editable": false,
      "key_states": ["默认占位", "聚焦输入"]
    },
    {
      "content_id": "publish-entry",
      "content": "发布产品入口",
      "group": "工具栏",
      "interaction": "action",
      "editable": false,
      "key_states": ["默认"]
    },
    {
      "content_id": "filter-tabs",
      "content": "动态筛选 Tab：全部 / 上新（上新带未读计数）",
      "group": "筛选",
      "interaction": "select",
      "editable": false,
      "key_states": ["全部激活", "上新激活", "上新有未读"]
    },
    {
      "content_id": "feed-item-identity",
      "content": "动态发布者身份：头像、发布者名称、发布时间、来源",
      "group": "动态卡片",
      "interaction": "view",
      "editable": false,
      "key_states": ["默认"]
