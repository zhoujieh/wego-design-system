  "rule_sources": [
    { "source": "user-requirement", "supports": ["动态页优化需求：头像内容左右布局、0.5px 分割线、操作按钮 12px、图片用组件", "宿主 5 个固定 Tab 各自需要规格文档", "帮卖需求：动态卡片操作行最右侧加帮卖按钮，拉起加价卖半弹窗", "加价卖弹窗：标题+帮助入口、我的售价输入、实时收益、快捷加价、底部说明、帮卖并分享", "用户确认：帮卖按钮位于蓝色文字链操作行最右侧；半弹窗容器先自写后替换组件；分享流程 stub；加价数据固定模拟值"] },
    { "source": "existing-implementation", "supports": ["动态页当前业务内容：工具栏、筛选、动态卡片、九宫格、摘要卡、操作按钮", "现有操作行使用 link link--12 承载"] },
    { "source": "AGENTS.md", "supports": ["宿主定义壳，5 个固定 Tab 各自需规格文档", "interaction_spec 落盘规则", "原型必须体现真实业务状态和流程反馈"] },
    { "source": "wego-product/SKILL.md", "supports": ["interaction_spec 结构和字段", "ready-with-assumptions 流转规则", "surface carrier=sheet 表达半弹窗意图"] }
