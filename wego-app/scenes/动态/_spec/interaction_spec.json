      "key_states": ["默认", "加载中", "加载失败"]
    },
    {
      "content_id": "feed-item-summary",
      "content": "产品摘要：缩略图、产品标题、价格、开单按钮",
      "group": "动态卡片",
      "interaction": "action",
      "editable": false,
      "key_states": ["默认"]
    },
    {
      "content_id": "feed-item-info",
