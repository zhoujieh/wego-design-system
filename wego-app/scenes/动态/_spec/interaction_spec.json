{
  "task_type": "design-system-consumption",
  "scene_category": "list",
  "goal": "让用户在动态 Tab 浏览产品动态流，快速查看、筛选和操作自己的产品动态",
  "scope": {
    "included": [
      "动态流列表页：工具栏（搜索入口 + 发布入口）",
      "筛选 Tab（全部 / 上新）",
      "动态卡片列表（发布者身份、动态标题、产品九宫格图、产品摘要、产品信息、操作按钮）"
    ],
    "excluded": [
      "发布产品完整流程（已有独立场景）",
      "产品详情页",
      "搜索结果页",
      "图片搜索识别流程"
    ]
  },
  "actors": [
    { "id": "shop-owner", "role": "店主", "purpose": "浏览和操作自己的产品动态" }
  ],
  "entry_points": [
    {
      "id": "dongtai-tab",
      "carrier": "host-fixed-tab",
      "description": "宿主底部第一个固定 Tab，点击切换到动态页"
    }
  ],
  "flows": [
    {
      "flow_id": "browse-feed",
      "flow_type": "main",
      "entry_node": "enter-feed",
      "steps": ["enter-feed", "browse-list", "filter-feed", "operate-item"],
      "exit_condition": "切换到其他 Tab"
    }
  ],
  "flow_nodes": [
    {
      "node_id": "enter-feed",
      "purpose": "进入动态 Tab，展示动态流",
      "surface_ref": "dynamic-feed-main",
      "inputs": [],
      "outputs": ["动态列表数据"],
      "key_states": ["已有数据态", "空态", "加载态"]
    },
    {
      "node_id": "browse-list",
      "purpose": "浏览动态卡片列表",
      "surface_ref": "dynamic-feed-main",
      "inputs": ["动态列表数据"],
      "outputs": [],
      "key_states": ["滚动浏览"]
    },
    {
      "node_id": "filter-feed",
      "purpose": "按全部/上新筛选动态",
      "surface_ref": "dynamic-feed-main",
      "inputs": ["筛选 Tab 选择"],
      "outputs": ["筛选后列表"],
      "key_states": ["全部", "上新"]
    },
    {
      "node_id": "operate-item",
      "purpose": "对单条动态执行操作（删除/下架/刷新/置顶/编辑）",
      "surface_ref": "dynamic-feed-main",
      "inputs": ["目标动态"],
      "outputs": ["操作结果"],
      "key_states": ["操作前", "操作反馈"]
    }
  ],
  "surfaces": [
    {
      "surface_id": "dynamic-feed-main",
      "role": "primary-task-page",
      "carrier": "host-fixed-tab",
      "node_refs": ["enter-feed", "browse-list", "filter-feed", "operate-item"],
      "content_refs": [
        "search-entry",
        "publish-entry",
        "filter-tabs",
        "feed-item-identity",
        "feed-item-title",
        "feed-item-gallery",
        "feed-item-summary",
        "feed-item-info",
        "feed-item-actions"
      ],
      "interaction_mode": "instant-apply",
      "purpose": "动态 Tab 主页面，承载动态流浏览、筛选和单条操作",
      "states": ["已有数据态", "空态", "加载态"]
    }
  ],
  "content_blocks": [
    {
      "content_id": "search-entry",
      "content": "搜索入口，支持按标题/搜索码/货号搜索，以及图片搜索",
      "group": "工具栏",
      "interaction": "action",
      "editable": false,
      "key_states": ["默认占位", "聚焦输入"]
    },
    {
      "content_id": "publish-entry",
      "content": "发布产品入口",
      "group": "工具栏",
      "interaction": "action",
      "editable": false,
      "key_states": ["默认"]
    },
    {
      "content_id": "filter-tabs",
      "content": "动态筛选 Tab：全部 / 上新（上新带未读计数）",
      "group": "筛选",
      "interaction": "select",
      "editable": false,
      "key_states": ["全部激活", "上新激活", "上新有未读"]
    },
    {
      "content_id": "feed-item-identity",
      "content": "动态发布者身份：头像、发布者名称、发布时间、来源",
      "group": "动态卡片",
      "interaction": "view",
      "editable": false,
      "key_states": ["默认"]
    },
    {
      "content_id": "feed-item-title",
      "content": "动态标题/正文",
      "group": "动态卡片",
      "interaction": "view",
      "editable": false,
      "key_states": ["默认"]
    },
    {
      "content_id": "feed-item-gallery",
      "content": "产品图片九宫格展示",
      "group": "动态卡片",
      "interaction": "view",
      "editable": false,
      "key_states": ["默认", "加载中", "加载失败"]
    },
    {
      "content_id": "feed-item-summary",
      "content": "产品摘要：缩略图、产品标题、价格、开单按钮",
      "group": "动态卡片",
      "interaction": "action",
      "editable": false,
      "key_states": ["默认"]
    },
    {
      "content_id": "feed-item-info",
      "content": "产品信息摘要行（如规格、库存等关键信息）",
      "group": "动态卡片",
      "interaction": "view",
      "editable": false,
      "key_states": ["默认", "无信息"]
    },
    {
      "content_id": "feed-item-actions",
      "content": "单条动态操作：删除、下架、刷新、置顶、编辑",
      "group": "动态卡片",
      "interaction": "action",
      "editable": false,
      "key_states": ["默认", "操作反馈"]
    }
  ],
  "transitions": [
    {
      "transition_id": "enter-to-browse",
      "from": "enter-feed",
      "trigger": "动态加载完成",
      "to": "browse-list",
      "data_in": [],
      "result_out": ["动态列表数据"]
    },
    {
      "transition_id": "browse-to-filter",
      "from": "browse-list",
      "trigger": "切换筛选 Tab",
      "to": "filter-feed",
      "data_in": ["filter-tabs 选择"],
      "result_out": ["筛选后列表"]
    },
    {
      "transition_id": "browse-to-operate",
      "from": "browse-list",
      "trigger": "点击单条动态操作按钮",
      "to": "operate-item",
      "data_in": ["目标动态"],
      "result_out": ["操作结果"]
    }
  ],
  "data_handoffs": [],
  "prototype_boundaries": [
    {
      "node_id": "enter-feed",
      "depth": "simulated",
      "reason": "使用本地模拟动态数据展示完整列表"
    },
    {
      "node_id": "browse-list",
      "depth": "functional",
      "reason": "列表可滚动浏览"
    },
    {
      "node_id": "filter-feed",
      "depth": "simulated",
      "reason": "筛选切换可交互，数据为模拟"
    },
    {
      "node_id": "operate-item",
      "depth": "stub",
      "reason": "操作按钮本次只提供入口和反馈，不实现完整业务操作",
      "feedback": "toast 提示操作已触发（如\"功能开发中\"）"
    }
  ],
  "states": [
    { "id": "has-data", "description": "已有动态数据，正常展示列表" },
    { "id": "empty", "description": "无动态数据，展示空态" },
    { "id": "loading", "description": "动态加载中" }
  ],
  "assumptions": [
    {
      "assumption": "动态页作为宿主固定 Tab，通过底部导航切换进入，不注册 hash push 路由；prototype_target.routes 留空数组，surface 用 carrier:host-fixed-tab 表达，host_container.tab=dongtai 标识归属。运行时 Tab 切换仍由 app.js setActiveTab 处理，内容仍用宿主增强脚本(dynamic-feed.js + dynamic-feed.css)，不迁移到 scene.js 结构",
      "impact_level": "low",
      "reversible": true
    },
    {
      "assumption": "本次优化聚焦展示细节（头像与内容左右布局、0.5px 分割线左对齐右贴边、操作按钮 12px link、九宫格用 image 组件），业务内容不变，具体视觉决策由 design_plan 承载",
      "impact_level": "low",
      "reversible": true
    }
  ],
  "open_questions": [],
  "readiness": {
    "status": "ready-with-assumptions",
    "reason": "业务内容、流程和状态明确；路由方案已确定（固定 Tab 不注册 push 路由，规格层用 carrier:host-fixed-tab 表达），仅有低风险可逆假设"
  },
  "app_target": {
    "mode": "wego-app-scene",
    "app_root": "wego-app",
    "scene_folder": "wego-app/scenes/动态",
    "runtime_entry": "scene.js",
    "route_mode": "hash"
  },
  "host_container": {
    "tab": "dongtai",
    "entry_label": "动态",
    "subentry_label": "",
    "leaf_level": 1,
    "entry_type": "cell",
    "needs_host_entry_surface": false
  },
  "prototype_target": {
    "app_root": "wego-app",
    "scenario_folder": "wego-app/scenes/动态",
    "routes": []
  },
  "rule_sources": [
    { "source": "user-requirement", "supports": ["动态页优化需求：头像内容左右布局、0.5px 分割线、操作按钮 12px、图片用组件", "宿主 5 个固定 Tab 各自需要规格文档"] },
    { "source": "existing-implementation", "supports": ["动态页当前业务内容：工具栏、筛选、动态卡片、九宫格、摘要卡、操作按钮"] },
    { "source": "AGENTS.md", "supports": ["宿主定义壳，5 个固定 Tab 各自需规格文档", "interaction_spec 落盘规则"] },
    { "source": "wego-product/SKILL.md", "supports": ["interaction_spec 结构和字段", "ready-with-assumptions 流转规则"] }
  ],
  "delivery_hint": "next-step"
}
