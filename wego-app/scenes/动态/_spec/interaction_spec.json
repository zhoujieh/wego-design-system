  "states": [
    { "id": "has-data", "description": "已有动态数据，正常展示列表" },
    { "id": "empty", "description": "无动态数据，展示空态" },
    { "id": "loading", "description": "动态加载中" },
    { "id": "resale-sheet-open", "description": "加价卖半弹窗已打开，覆盖在动态页之上" },
    { "id": "resale-input-invalid", "description": "售价输入非法，输入框错误态且主按钮禁用" }
  ],
  "assumptions": [
    {
      "assumption": "动态页作为宿主固定 Tab，通过底部导航切换进入，不注册 hash push 路由；prototype_target.routes 留空数组，surface 用 carrier:host-fixed-tab 表达，host_container.tab=dongtai 标识归属。运行时 Tab 切换仍由 app.js setActiveTab 处理，内容仍用宿主增强脚本(dynamic-feed.js + dynamic-feed.css)，不迁移到 scene.js 结构",
      "impact_level": "low",
      "reversible": true
    },
    {
      "assumption": "加价卖半弹窗作为 sheet 覆盖在动态页之上，不注册独立 hash 路由；半弹窗容器组件目前缺失，本次原型由场景级自写承载，并在 design_plan 中标注待替换为正式 modal 组件",
      "impact_level": "low",
      "reversible": true
    },
    {
      "assumption": "推荐加价比例固定模拟为+30%（对应需求示例商品售价¥20→默认售价¥26），快捷按钮固定+20%；商品售价使用模拟数据(如¥20)",
      "impact_level": "low",
      "reversible": true
    },
    {
      "assumption": "售价校验上限取商品售价×10，超出范围提示错误（需求未给出具体上限，取合理值）",
      "impact_level": "low",
      "reversible": true
    },
    {
      "assumption": "加价卖说明'?'入口跳转外链 https://mp.weixin.qq.com/s/H05MjX1OTmng8nXVl3GXrQ，不在原型内实现说明详情页",
      "impact_level": "low",
      "reversible": true
    },
    {
      "assumption": "关闭弹窗(X/下滑/遮罩)不保存未确认修改，再次进入重新填入默认推荐价",
      "impact_level": "low",
      "reversible": true
    }
  ],
  "open_questions": [],
  "readiness": {
    "status": "ready-with-assumptions",
    "reason": "帮卖入口、加价卖弹窗的内容、流程、状态和原型深度均已明确；半弹窗容器由场景级自写承载并标注待替换为正式 modal 组件；仅存低风险可逆假设（模拟数据、校验上限、外链跳转）"
  },
