  ],
  "flows": [
    { "id": "configure-product-note", "type": "main", "goal": "进入并调整产品与笔记设置", "nodes": ["enter-product-note", "view-product-note-list", "toggle-product-note-setting", "return-system-settings"] },
    { "id": "open-product-note-stub-entry", "type": "branch", "goal": "点击未接入下钻入口时给出反馈", "nodes": ["view-product-note-list", "tap-product-note-stub", "show-stub-toast"] }
