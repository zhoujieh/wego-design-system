  "goal": "让商家在补货商品选择页搜索、勾选和取消勾选商品，最多选择 5 个商品，并把选择结果返回补货计划页。",
  "scope": {
    "included": [
      "从补货计划页 push 打开商品选择页",
      "商品搜索",
      "勾选与取消勾选",
      "最多 5 个商品的上限控制和明确反馈",
      "点击完成返回补货计划页并回填选择结果",
      "取消返回",
      "再次进入时恢复本次会话中的勾选状态"
    ],
    "excluded": [
      "真实商品搜索接口",
      "分页加载",
      "真实库存同步",
      "刷新后恢复会话"
    ]
  },
  "actors": [
    {
      "id": "merchant-operator",
      "role": "商家经营者",
      "purpose": "从候选商品中快速选出需要补货的商品"
    }
  ],
  "entry_points": [
    {
      "id": "restock-plan-add-products",
      "carrier": "push-navigation",
      "description": "补货计划页点击添加补货商品后 push 进入商品选择页"
    }
  ],
  "interaction_mode": "select-return",
