  "page_strategy": {
    "page_goal": "让商家在一个主页面内完成补货商品回填、数量编辑、错误修正和统一保存。",
    "page_pattern": "generic-mobile-task-page",
    "layout_pattern": "卡片模式 M16",
    "main_scroll_direction": "vertical",
    "content_density": "medium",
    "fixed_vs_scroll": "navbar sticky；页面主体滚动；保存按钮在内容底部作为页面主操作，不做吸底悬浮。",
    "first_screen_goal": "首次进入立即感知空状态主动作；已有商品时首屏优先看到计划状态、商品列表起始区和补货数量输入。",
    "region_priority": [
      "plan-summary-region",
      "empty-or-list-region",
      "secondary-action-region",
      "submit-region"
    ],
    "scroll_rhythm": "导航栏下先给计划状态/空状态，主体各分组间距 12px；商品卡片内部用 8px/12px 节奏组织信息、输入和错误提示。",
    "visual_competition": "空状态主按钮和保存按钮是最强视觉主操作；商品名称和数量输入为列表内主信息，库存与商品 ID 降为次级说明。"
  },
