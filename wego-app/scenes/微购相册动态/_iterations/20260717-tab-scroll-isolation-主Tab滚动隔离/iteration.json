    "goal": "让用户在五个主业务入口之间切换时，始终从目标入口的默认起始位置浏览，避免一个入口的浏览位置影响其他入口。",
    "included": [
      "动态、好友、工作台、消息和我的五个主业务入口分别承载各自的浏览位置",
      "用户切换主业务入口时，目标入口回到默认起始位置",
      "用户切换主业务入口时，其他入口不继承当前入口的浏览位置",
      "用户再次进入曾经浏览过的主业务入口时，该入口回到默认起始位置",
      "全面审查并清理主业务入口切换与浏览位置之间的冲突逻辑"
    ],
    "excluded": [
      "修改五个主业务入口的业务内容、文案或功能范围",
      "修改二级页面、弹层和独立业务流程的返回位置规则",
      "刷新后保存任一主业务入口的浏览位置",
      "新增真实后端接口或数据持久化"
    ],
    "entry_points": [
      "微购 App 的动态、好友、工作台、消息和我的五个主业务入口"
    ],
    "critical_paths": [
      "进入动态主业务入口并浏览内容 → 切换到其他主业务入口 → 目标入口从默认起始位置展示",
      "进入任一主业务入口并浏览内容 → 依次切换多个主业务入口 → 每个目标入口均从默认起始位置展示",
      "返回曾经浏览过的主业务入口 → 该入口从默认起始位置重新展示"
    ],
    "prototype_boundaries": [
