  "prototype_brief": {
    "goal": "重新设计「动态」主 tab，让用户能更高效地浏览好友动态与商品上新，并通过搜索和快捷入口快速定位好友或商品内容。",
    "included": [
      "完全替代现有「相册动态」页面内容与排版",
      "顶部固定搜索区，支持按好友昵称、商品名称、动态文案实时过滤",
      "横向好友快捷入口，头像与数据直接取自「好友」tab 的 FRIENDS_DATA",
      "顶部标签筛选：全部、好友上新、图文动态",
      "动态信息流卡片：发布者头像/名称、发布时间、动态文案、图片网格、关联商品卡片",
      "搜索无结果空状态",
      "点击好友头像后动态流切换为仅该好友的内容，并提供清除过滤入口",
      "点击商品/图片/更多操作时给出 Toast 或底部操作面板反馈，不打开新页面"
    ],
    "excluded": [
      "搜索下钻结果页、好友主页、商品详情页等二级页面",
      "真实后端接口、数据持久化、动态发布功能",
      "评论、点赞、转发的真实业务闭环",
      "消息、工作台、我的 tab 的业务内容修改"
    ],
    "entry_points": [
      "底部导航「动态」主 tab（dongtai）"
    ],
    "critical_paths": [
      "进入动态 tab → 上下滚动浏览混合信息流 → 切换顶部标签筛选内容类型",
      "进入动态 tab → 在搜索框输入关键词 → 查看实时过滤后的动态结果",
      "进入动态 tab → 点击横向好友头像 → 动态流过滤为该好友内容 → 可清除过滤回到全部",
      "点击动态卡片上的商品/图片/更多操作 → 获得即时反馈"
    ],
