{
  "spec_id": "mvp001-warehouse-management",
  "spec_purpose": "MVP 验证用交互规格，面向 Figma MCP 写入计划，独立于 _spec/ 下的正式规格",
  "user_goal": "店主集中维护仓库资料，覆盖列表浏览、新增、编辑、删除和空状态新增五个核心流程",
  "page_entry": {
    "route_id": "my-warehouse-management",
    "entry_carrier": "host-grid-entry",
    "host_tab": "my",
    "host_group": "my-app-center",
    "entry_label": "仓库管理"
  },
  "flows": [
    {
      "flow_id": "F01",
      "flow_name": "仓库列表浏览流程",
      "flow_type": "main",
      "steps": [
        "enter-warehouse",
        "view-list",
        "browse-summary",
        "browse-cards"
      ],
      "start_point": "我的 Tab 应用中心点击仓库管理入口",
      "end_result": "用户停留在列表页浏览仓库资料"
    },
    {
      "flow_id": "F02",
      "flow_name": "新增仓库流程",
      "flow_type": "main",
      "steps": [
        "view-list",
        "click-create",
        "open-create-editor",
        "fill-form",
        "save-warehouse",
        "return-list-saved"
      ],
      "start_point": "列表页点击 navbar 右侧「新建」按钮",
      "end_result": "新仓库插入列表顶部，toast 提示「仓库已新增」"
    },
    {
      "flow_id": "F03",
      "flow_name": "编辑仓库流程",
      "flow_type": "branch",
      "steps": [
        "view-list",
        "open-card-menu",
        "click-edit",
        "open-edit-editor",
        "modify-form",
        "save-warehouse",
        "return-list-saved"
      ],
      "start_point": "列表页点击某张仓库卡片的更多按钮",
      "end_result": "对应仓库在列表原位更新，toast 提示「仓库已更新」"
    },
    {
      "flow_id": "F04",
      "flow_name": "删除仓库流程",
      "flow_type": "branch",
      "steps": [
        "view-list",
        "open-card-menu",
        "click-delete",
        "confirm-delete-dialog",
        "execute-delete",
        "return-list-deleted"
      ],
      "start_point": "列表页点击某张仓库卡片的更多按钮",
      "end_result": "对应仓库从列表移除，toast 提示「仓库已删除」"
    },
    {
      "flow_id": "F05",
      "flow_name": "空状态新增流程",
      "flow_type": "branch",
      "steps": [
        "view-empty-list",
        "click-create-first",
        "open-create-editor",
        "fill-form",
        "save-warehouse",
        "return-list-saved"
      ],
      "start_point": "列表为空时点击「新增仓库」按钮",
      "end_result": "首个仓库出现在列表中，toast 提示「仓库已新增」"
    }
  ],
  "flow_nodes": [
