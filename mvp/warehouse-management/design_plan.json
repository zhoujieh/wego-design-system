{
  "plan_id": "mvp001-warehouse-management-design",
  "plan_purpose": "MVP 验证用设计规格，面向 Figma MCP 写入计划，基于 scene.css 实际布局",
  "page_split": [
    {
      "page_id": "P01",
      "page_name": "仓库管理列表页",
      "surface_ref": "warehouse-list",
      "carrier": "push",
      "transition": "slide-left",
      "covers_tab_bar": true,
      "used_by_flows": ["F01", "F02", "F03", "F04", "F05"]
    },
    {
      "page_id": "P02",
      "page_name": "新增仓库页",
      "surface_ref": "warehouse-editor",
      "carrier": "full-screen-modal",
      "transition": "slide-up-enter, slide-down-exit",
      "covers_tab_bar": true,
      "used_by_flows": ["F02", "F05"],
      "mode": "create"
    },
    {
      "page_id": "P03",
      "page_name": "编辑仓库页",
      "surface_ref": "warehouse-editor",
      "carrier": "full-screen-modal",
      "transition": "slide-up-enter, slide-down-exit",
      "covers_tab_bar": true,
      "used_by_flows": ["F03"],
      "mode": "edit"
    },
    {
      "page_id": "P04",
      "page_name": "删除确认弹窗",
      "surface_ref": "delete-dialog",
      "carrier": "dialog",
      "transition": "fade",
      "covers_tab_bar": false,
      "used_by_flows": ["F04"]
    }
  ],
  "page_strategy": {
    "page_goal": "让店主集中维护仓库资料，保证新增、编辑、删除都有明确闭环",
    "page_pattern": "object-management-list-with-editor",
    "primary_scroll": "vertical",
    "density": "medium-high",
    "first_screen_priority": ["导航栏", "新建入口", "仓库摘要", "仓库卡片列表"]
  },
  "surface_types": [
    {
      "surface_id": "warehouse-list",
      "role": "primary-task-page",
      "carrier": "push-page",
      "purpose": "仓库列表页，承载摘要、卡片、空状态、更多菜单"
    },
    {
      "surface_id": "warehouse-editor",
      "role": "secondary-task-page",
      "carrier": "full-screen-modal",
      "purpose": "新增/编辑仓库表单，五个分组垂直堆叠"
    },
    {
      "surface_id": "delete-dialog",
      "role": "secondary-task-page",
      "carrier": "dialog",
      "purpose": "删除二次确认"
    }
  ],
  "region_layouts": [
    {
      "surface_ref": "warehouse-list",
      "regions": [
        { "region_id": "navbar", "role": "navigation", "layout": "horizontal-3-slot", "scroll_behavior": "fixed", "order": 1, "components": ["返回按钮", "标题", "新建按钮"] },
        { "region_id": "summary", "role": "statistics", "layout": "vertical-stack", "scroll_behavior": "scroll", "order": 2, "components": ["已接入仓库 X 个", "启用中 X 个，默认发货仓 X 个"] },
        { "region_id": "warehouse-list", "role": "object-list", "layout": "vertical-stack", "scroll_behavior": "scroll", "order": 3, "components": ["仓库卡片 × N 或 空状态"] }
      ]
    },
    {
      "surface_ref": "warehouse-editor",
      "regions": [
        { "region_id": "modal-navbar", "role": "navigation", "layout": "horizontal-3-slot", "scroll_behavior": "fixed", "order": 1, "components": ["取消按钮", "标题（新增/编辑仓库）", "保存按钮"] },
        { "region_id": "form-body", "role": "form-content", "layout": "vertical-stack", "scroll_behavior": "scroll", "order": 2, "components": ["仓库状态分组", "基础信息分组", "履约能力分组", "库存与发货分组", "补充信息分组"] },
        { "region_id": "save-action", "role": "submit-action", "layout": "navbar-right", "scroll_behavior": "fixed", "order": 3, "components": ["保存按钮（navbar 右侧）"] }
      ]
    },
    {
      "surface_ref": "delete-dialog",
      "regions": [
        { "region_id": "dialog-content", "role": "risk-confirmation", "layout": "vertical-stack", "scroll_behavior": "static", "order": 1, "components": ["标题", "内容文案"] },
        { "region_id": "dialog-actions", "role": "confirm-cancel", "layout": "horizontal-row", "scroll_behavior": "static", "order": 2, "components": ["取消按钮", "删除按钮"] }
      ]
    }
  ],
  "state_displays": [
    {
      "state_id": "S01",
      "display": "卡片徽章：默认发货仓=brand高亮、启用中=success绿、已停用=subtle灰；摘要区显示总数/启用数/默认仓数"
    },
    {
      "state_id": "S02",
      "display": "空状态组件：圆形品牌色图标 + 「还没有仓库」标题 + 引导文案 + 「新增仓库」strong 按钮"
    },
    {
      "state_id": "S03",
      "display": "卡片更多按钮下方展开操作菜单，带向上箭头小三角，含「编辑」和「删除」（danger 红色）"
    },
    {
      "state_id": "S04",
      "display": "空表单含默认值：类型=直营网仓、服务范围=多渠道履约、时效=24小时内发货、温层=常温、安全库存=10、单日上限=500"
    },
    {
      "state_id": "S05",
      "display": "表单回填已有仓库全部字段，标题改为「编辑仓库」，封面图使用已有 imageUrl 或按名称生成示意图"
    },
    {
      "state_id": "S06",
      "display": "表单保持当前内容，顶部 toast 提示校验失败原因（如「请先填写仓库名称」）"
    },
    {
      "state_id": "S07",
      "display": "编辑 modal 关闭，列表页显示 toast「仓库已新增/已更新」，列表回填（新增置顶或编辑原位更新）"
    },
    {
      "state_id": "S08",
      "display": "列表上方弹出 dialog：标题「确认删除仓库？」、内容含仓库名称、按钮「取消」+「删除」（danger）"
    },
    {
      "state_id": "S09",
      "display": "dialog 关闭，列表移除对应卡片，toast 提示「仓库已删除」"
    }
  ],
  "component_patterns": [
    {
      "pattern_id": "CP01",
      "applies_to": ["仓库卡片"],
      "component": "card",
      "variant": "card--surface",
      "description": "卡片含封面图(64×64 rounded-md)、标题、徽章组、摘要、更多按钮"
    },
    {
      "pattern_id": "CP02",
      "applies_to": ["新建按钮", "新增仓库按钮"],
      "component": "button",
      "variant": "btn--strong btn--md / btn--sm",
      "description": "navbar 新建用 sm，空状态新增用 md"
    },
    {
      "pattern_id": "CP03",
      "applies_to": ["更多按钮"],
      "component": "button",
      "variant": "icon-only 32×32",
      "description": "圆角 6px，图标 icon-sandian16"
    },
    {
      "pattern_id": "CP04",
      "applies_to": ["删除菜单项"],
      "component": "menu-item",
      "variant": "danger",
      "description": "36px 高，文字使用 status-danger-default 色"
    },
    {
      "pattern_id": "CP05",
      "applies_to": ["启用仓库", "默认发货仓", "支持同城配送", "支持门店自提", "支持直播备货", "锁定预占库存", "跨区域调拨"],
      "component": "switch",
      "variant": "switch--on / switch--off",
      "description": "开关组件，aria-checked 状态切换"
    },
    {
      "pattern_id": "CP06",
      "applies_to": ["仓库名称", "仓库编码", "联系人", "定位备注", "门头图链接"],
      "component": "form-input",
      "variant": "horizontal text input",
      "description": "form-body 横向布局，必填项带 (必填) 标记"
    },
    {
      "pattern_id": "CP07",
      "applies_to": ["联系电话"],
      "component": "form-input",
      "variant": "phone-input with +86 prefix",
      "description": "inputmode=numeric, maxlength=11"
    },
    {
      "pattern_id": "CP08",
      "applies_to": ["仓库地址", "仓库备注"],
      "component": "form-textarea",
      "variant": "vertical textarea",
      "description": "form-body--vertical 布局"
    },
    {
      "pattern_id": "CP09",
      "applies_to": ["安全库存", "单日上限"],
      "component": "number-input",
      "variant": "number-input--surface-white with suffix",
      "description": "inputmode=numeric，带「件」「单」后缀"
    },
    {
      "pattern_id": "CP10",
      "applies_to": ["仓库类型", "服务范围", "发货时效", "温层要求"],
      "component": "cell-select",
      "variant": "cycle-select",
      "description": "点击循环切换选项，cell 或 form-body--clickable 承载"
    },
    {
      "pattern_id": "CP11",
      "applies_to": ["删除确认弹窗"],
      "component": "dialog",
      "variant": "text variant",
      "description": "标题+内容+两按钮（dismiss + danger）"
    },
    {
      "pattern_id": "CP12",
      "applies_to": ["保存按钮"],
      "component": "button",
      "variant": "btn--strong btn--sm",
      "description": "navbar 右侧固定主操作"
    }
  ],
  "layout_constraints": [
    "列表页使用卡片模式：phone-body 16px 横向 padding",
    "编辑页使用通栏模式：form-group 内部 0px 横向 padding，分组间 spacer-8 间距",
    "navbar 背景跟随 data-bg=surface 白底",
    "删除 dialog 使用标准 dialog 组件，不发明自定义弹窗",
    "空状态垂直居中，padding 40px 20px"
  ]
}
