  "structurePatterns": [
    "默认固定五项布局，图标在上、文字在下，顺序为：动态、好友、工作台、消息、我的。",
    "文案和图标资产是组件固定内容，使用时直接复制 preview 中对应 markup，不通过业务运行时传入动态配置。",
    "角标嵌套在 icon 区，不额外发明导航项结构。",
    "safe-area 底部补偿由组件自身承担。",
    "root、item 和 icon 承载区保持 overflow: visible，避免角标被组件容器裁剪。"
  ],
  "behavior": {
    "pressFeedback": "移动端按压态由 :active 与 .is-pressed 共同承载。宿主 App 通过 wego-app/js/app.js 在触控设备上自动为 .bottom-nav__item 等可点击元素添加/移除 .is-pressed；桌面端继续由 :active 兜底。同时设置 -webkit-user-select: none / user-select: none 以禁用长按文本选择和拖杆控件。",
    "selection": "同一时刻只允许一个激活项。",
    "badge": "角标只作为状态附着，不改变导航项主布局。",
    "pageMode": "主导航切换场景使用，不承载二级筛选或工具操作。"
  },
  "accessibility": {
    "role": "tablist 或 navigation",
    "activeState": "激活项需要可感知的选中状态标识。",
    "labelRule": "图标必须配套固定中文文案，不使用仅图标导航。"
  },
  "usageHints": [
    "用于 App 级主框架，不用于弹层、表单或单页局部切换。",
    "保持固定五个一层入口，避免改成四项、六项或业务动作工具条。",
    "如果业务页面只需要某几个入口，也不要删除导航项；未接入的入口可暂不绑定跳转。"
  ],
  "doNotInvent": [
    "不要把 bottom-nav 扩成营销浮动工具条、桌面侧边栏或多行导航。",
    "不要把文案、图标、入口数量做成运行时动态配置。",
    "不要引入 Lucide 或外部图标体系替代库内资产。"
  ],
