  "structurePatterns": [
    "根节点始终使用 .btn，并叠加强调级别、尺寸和状态类。",
    "带图标模式使用前置 .btn__icon，纯图标模式仍保留 .btn 根节点但不放文字。",
    "纯图标和带图标按钮只用于新建场景，其它场景默认使用纯文字按钮。"
  ],
  "behavior": {
    "pressFeedback": "移动端按压态由 :active 与 .is-pressed 共同承载。宿主 App 通过 wego-app/js/app.js 在触控设备上自动为 button、.btn 等可点击元素添加/移除 .is-pressed；桌面端继续由 :active 兜底。同时设置 -webkit-user-select: none / user-select: none 以禁用长按文本选择和拖杆控件。",
    "interaction": "按下态通过背景色过渡表达，disabled 时禁用 hover 和 active 响应。",
    "iconOnly": "纯图标模式沿用相同状态机，不新增独立视觉体系，仅作为新建入口使用。",
    "primaryRule": "strong 只用于当前页面最核心的操作，同一页面只允许出现 1 个 strong 按钮。"
  },
  "accessibility": {
    "role": "button",
    "disabledState": "原生按钮优先使用 disabled；非原生场景使用 aria-disabled。btn--disabled 仅作为显式状态类补充，不应替代语义属性。",
    "labelRule": "纯图标模式必须提供可感知名称，例如 aria-label。",
    "touchTarget": "热区扩展以不破坏布局为前提，仅对点击目标小于 32px 的元素进行伪元素补偿。"
  },
  "usageHints": [
    "strong 用于当前页面最核心的操作，同页仅保留 1 个。",
    "medium 适合主操作旁边的重要次级动作。",
    "weak 适合列表、表单区或局部区域内的次级操作。",
    "danger 用于删除、清空、停用等明确危险动作，默认以灰底红字呈现。",
    "按钮文案由业务侧按文案规范自行书写，组件不预设固定业务文案。"
  ],
  "doNotInvent": [
    "不要扩展为营销横幅按钮、胶囊筛选标签或桌面工具栏按钮。",
    "不要在单页放置多个 strong 主按钮并列竞争注意力。",
    "不要为单个业务场景新增临时颜色按钮。",
    "不要在非新建场景使用纯图标或带图标按钮。"
  ],
