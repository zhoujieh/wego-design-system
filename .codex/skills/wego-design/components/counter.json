  "structurePatterns": [
    "主区始终由减号按钮、数值输入、加号按钮组成。",
    "提示和错误信息位于组件下方，共用单一消息槽位，不挤占主操作区高度；长文案单行省略。",
    "热区依赖按钮伪元素扩展，不通过增高组件本体实现。"
  ],
  "behavior": {
    "pressFeedback": "移动端按压态由 :active 与 .is-pressed 共同承载。宿主 App 通过 wego-app/js/app.js 在触控设备上自动为 .counter__btn 等可点击元素添加/移除 .is-pressed；桌面端继续由 :active 兜底。同时设置 -webkit-user-select: none / user-select: none 以禁用长按文本选择和拖杆控件。",
    "step": "点击减号或加号按最小步长增减，尊重 data-counter-min 与 data-counter-max。",
    "input": "输入框只接受 0-9 数字字符；等于最大值时保持合法，只有超过最大值或低于最小值时才进入错误校验；重新回到合法范围后自动移除错误态并恢复默认或提示态。",
    "disabled": "禁用态禁止按钮和输入交互。"
  },
  "accessibility": {
    "buttonLabels": [
      "减少",
      "增加"
    ],
    "inputMode": "numeric",
    "touchRule": "视觉尺寸保持 32px，高频场景靠伪元素扩展到至少 40px 热区。"
  },
  "usageHints": [
    "用于商品详情、购物车和库存配置等需要连续增减的场景。",
    "提示文案适合说明库存、起购量等轻反馈；错误文案只在越界或非法输入时出现。",
    "嵌入 form 等宿主场景时，仍沿用 counter 自身的图标尺寸、按钮尺寸和输入字号；若宿主已提供统一消息槽位，可隐藏 counter 自身底部消息位并由宿主承接反馈。"
  ],
  "doNotInvent": [
