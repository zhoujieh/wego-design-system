  "structurePatterns": [
    "默认业务挂载使用 corner，Badge 绝对定位在宿主右上角，宿主需提供 position: relative。",
    "dot 在 corner 下使用更贴边的偏移规则，与宿主形成约 1-2px 的轻微重叠。",
    "文字类在 corner 下直接使用左上、右上、右下 8px 与左下 1px 的圆角轮廓，在 inline 下固定为跑道圆胶囊形。"
  ],
  "behavior": {
    "defaultPlacement": "未显式指定时按 corner 语义处理，默认显示在宿主右上角。",
    "inlineRule": "inline 模式不使用绝对定位，只与文字、按钮或列表内容并排展示。",
    "textColorModel": "文字类默认背景色为 var(--accent-green)，可通过 --badge-text-bg 和 --badge-text-color 覆盖任意颜色。",
    "scrollable": "仅文字类支持 scrollable，默认宽度 32px，可通过 --badge-scroll-width 覆盖；交互为双轨道拼接的持续向左无缝循环轮播。"
  },
  "accessibility": {
    "hostRule": "corner 模式依附宿主元素展示，不单独承担可点击主操作语义。",
    "contentRule": "数字类优先用于未读数和数量提醒，文字类保持短词短句，自定义颜色时需保证文本对比度。"
  },
  "usageHints": [
    "dot 用于轻提醒，number 用于未读或数量，text 用于新品、热卖、补贴等短标签，remove 用于可移除标记。",
    "在导航、头像、图片卡片上优先使用 corner；在文本旁、按钮旁、列表操作区优先使用 inline。"
  ],
  "doNotInvent": [
    "不要把 badge 扩成长句横幅、统计面板或多行提示气泡。",
    "不要在 inline 模式叠加角标定位类，也不要用 remove 替代真正的关闭按钮。"
  ],
