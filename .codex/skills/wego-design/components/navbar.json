  "structurePatterns": [
    "body 固定为三栏网格，不拆成桌面工具栏模式。",
    "右侧操作按文本、图标、图文、按钮等场景罗列，直接作为 navbar 内部样式场景维护，不再注册为独立组件。",
    "按钮式右侧操作复用已注册 button 组件的小尺寸按钮。",
    "无按钮模式只影响 left 与 center 布局，不改变 56px 导航栏高度。"
  ],
  "behavior": {
    "leftAction": "返回、关闭或取消属于左侧主导航操作，不与右侧按钮混用。",
    "title": "标题区允许居中或左对齐宽版，但保持单行省略。",
    "actionPress": "右侧操作以轻压暗或按钮背景变化反馈。",
    "pageTransitionRule": "左侧为返回图标 (back-icon) 对应 push 转场（右侧滑入，普通二级页）；左侧为关闭/叉 (close-icon) 或取消文本 (text-cancel) 对应 present 转场（底部滑入，弹出式页面）。",
    "fullscreenModalPatterns": "全屏模态页面有且仅有两种固定导航模式，不要自由组合：模式 A（取消文本 + 实心按钮）用于表单/设置类底部弹出页；模式 B（关闭叉图标 + 图标操作）用于浏览/选择类底部弹出页。",
    "backgroundRule": "导航栏必须显式设置背景色，与页面 data-bg 声明的背景色保持一致；默认 var(--bg-page)（灰色），data-bg=\"surface\" 时为 var(--bg-surface)（白色）；深色场景可使用 transparent，由宿主另行处理。"
  },
  "accessibility": {
    "landmark": "作为页面顶部导航语义区域使用。",
    "titleRule": "标题保持单行可感知，不依赖图标传达页面语义。",
    "actionNames": "右侧图标操作必须具备中文可感知名称。"
  },
  "usageHints": [
    "适合标准页面顶部导航、详情页返回和设置页保存动作。",
    "多个右侧动作应保持克制，优先一到两个高频操作。",
    "页面打开模式由左侧控件决定：返回图标 → 右侧滑入 (push)；关闭/叉/取消 → 底部滑入 (present / bottom-sheet)。",
    "所有左侧可交互内容点击热区通过伪元素扩大至 48px，不改变布局尺寸。",
    "右侧操作使用 navbar 内部 .navbar__action 结构；不要把它当独立组件消费。",
    "全屏模态页面直接调用固定模式，不要自由组合：模式 A（取消+按钮）用于表单/设置类；模式 B（叉+图标）用于浏览/选择类。",
    "导航栏必须显式设置背景色，与页面 data-bg 声明的背景色一致；不要使用 transparent（深色场景除外）。",
    "navbar 宽度默认 100%，由页面外层容器约束最大宽度（768px）；不需要在项目中覆盖宽度。",
    "navbar 组件本身不处理 sticky 定位。在全屏模态页中，宿主页面的布局容器需为 navbar 添加 position: sticky; top: 0; z-index: var(--z-sticky)，确保导航栏始终固定在视口顶部。"
  ],
  "doNotInvent": [
    "不要把 navbar 扩成桌面多行标题栏、营销大顶栏或搜索综合头部。",
    "不要把状态栏、标题栏和筛选条硬拼成单一组件。",
    "不要给 navbar 写死固定宽度（如 375px）；navbar 宽度默认 100%，由外层容器约束。"
  ],
