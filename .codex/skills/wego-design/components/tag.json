  "structurePatterns": [
    "20 规格用于纯展示，不附加交互态。",
    "24 规格用于入口跳转，不出现 selected 态。",
    "28 和 32 规格承载筛选或状态切换，可选是否 closable，同一状态下建议把可关闭与不可关闭示例并排展示。",
    "32-add 仅用于新增入口，不承担已选状态。",
    "coupon 使用 `.tag.tag--coupon` 根节点，仅表达固定业务语义，不与通用筛选标签混排成复杂组件。"
  ],
  "behavior": {},
  "accessibility": {},
  "usageHints": [
    "筛选场景优先使用 28 或 32 规格，保持一行内较高信息密度。",
    "品牌色只用于已选或强调，不大面积铺满整组标签。",
    "关闭图标和加号图标跟随标签文字色继承，避免额外写状态色覆盖。",
    "优惠类短标签保持独立语义，不与通用筛选标签混排成复杂组件。",
    "当 tag 宿主容器背景为灰色（如 --bg-subtle、--bg-page）时，使用 tag--white 主题以保证视觉对比，避免 tag--gray 与灰色背景融合不可见。"
  ],
  "doNotInvent": [
    "不要把 tag 扩成桌面 Tab、分段控件或可输入 token。",
    "不要新增夸张渐变、插画底纹或重阴影标签。"
  ],
