  "structurePatterns": [
    "尺寸、圆角、填充模式全部由修饰类叠加在同一根节点上。",
    "loading 使用根节点骨架动画，不额外发明新的宿主层级。",
    "error 通过占位层承载 default-diagram.svg，logo 按容器宽度约 40% 等比缩放，最大不超过 40px。",
    "clickable 仅补按压覆盖层，不扩展成轮播或缩放组件。"
  ],
  "behavior": {
    "pressFeedback": "移动端按压态由 :active 与 .is-pressed 共同承载。宿主 App 通过 wego-app/js/app.js 在触控设备上自动为 .wg-image--clickable 等可点击元素添加/移除 .is-pressed；桌面端继续由 :active 兜底。同时设置 -webkit-user-select: none / user-select: none 以禁用长按文本选择和拖杆控件。",
    "loading": "默认加载态使用 .wg-image--loading，在根节点显示浅灰骨架动画。",
    "loaded": "图片元素添加 .is-loaded 后以 0.2s 渐显。",
    "error": "失败态使用 .wg-image--error，并在 .wg-image__placeholder 内放置 default-diagram.svg。"
  },
  "accessibility": {},
  "usageHints": [
    "商品图优先使用矩形或宽幅规格，头像类场景使用 circle。",
    "对象管理列表中的识别图优先使用真实业务图片、真实对象缩略图或低饱和占位图；占位只辅助识别，不抢标题、状态和操作的视觉层级。",
    "contain 适合完整展示 logo、海报缩略或比例敏感资产。",
    "错误占位图使用 assets/icons/default-diagram.svg，图形按容器宽度约 40% 等比缩放，最大尺寸限制为 40px。",
    "error 占位只做兜底提示，不替代正式空状态组件。",
    "动态生成 wg-image 时，必须在 img 元素上监听 load 事件并添加 is-loaded class；wg-image__src 默认 opacity:0，只有 is-loaded 才可见。静态 HTML 可直接在 img 上写 is-loaded。"
  ],
  "doNotInvent": [
    "不要把 image 扩成轮播、视频播放器或带复杂编辑能力的媒体组件。",
    "不要新增重毛玻璃、渐变遮罩或夸张 loading 动画。",
    "不要在对象管理列表中用大面积高饱和渐变插画冒充真实业务图片；真实图片缺失时使用克制占位或默认占位资产。",
    "不要让失败占位 logo 随容器无限放大。"
  ],
