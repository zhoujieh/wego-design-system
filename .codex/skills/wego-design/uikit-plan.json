  "pagePatterns": [
    {
      "name": "业务规则配置",
      "slug": "biz-rule-config",
      "applicableScenarios": [
        "业务规则配置",
        "业务参数编辑",
        "权限管理",
        "库存规则维护",
        "发货规则维护",
        "业务数据编辑"
      ],
      "interactionPattern": "编辑后统一保存，页面级主操作收口，不在内容区和底部重复堆叠保存动作",
      "priority": "highest-for-settings-pages",
      "presentation": "full-screen-modal",
      "transition": "slide-up-enter, slide-down-exit",
      "dismissAction": "page-level-save",
      "overlayLevel": "overlay",
      "coversTabBar": true,
      "componentSlugs": [
        "navbar",
        "form",
        "cell",
        "checkbox",
        "switch",
        "radio",
        "tag",
        "link"
      ],
      "uikitFile": "ui_kits/biz-rule-config/index.html",
      "specRef": "specs/交互设计原则.md#页面模式与转场",
      "structureHighlights": [
        "使用编辑型二级页导航，页面级主操作统一收口",
        "页面顶部可放置摘要区（方案名称、状态、说明等），但摘要区不是必需结构——是否包含摘要区由原始业务需求决定；UI Kit 中的 biz-summary 是演示参考，不是页面范式的强制元素。",
        "整体保持高信息密度和连续设置节奏，避免做成松散营销页",
        "子级条件区域（left-guide）：子级 cell 缩进结构以 cell.json 的 structurePatterns 为权威来源，使用 cell__backspace 占位模式。父级 radio/checkbox 所在 cell 和子级 cell 应在同一 section-group 内连续排列，最后一行不加分割线。"
      ],
      "templates": [
        "业务配置",
        "价格规则设置",
        "成员权限设置",
        "库存预警设置"
      ],
      "leftGuidePattern": {
        "domPattern": ".cell > .cell__backspace（空占位） > .cell__select（switch/radio） > .cell__body",
        "rule": "子级 cell 使用缩进区空白占位实现缩进，复用已注册组件 class，不发明自定义 guide-line 样式",
        "indentWidth": "24px"
      },
      "compositionConstraints": [
        {
          "trigger": "多选项互斥单选（选项≥3 或单条文案>4字）",
          "use": "cell + cell__select + radio",
          "avoid": "form-body--preserve-content-align + radio-field-group",
          "reason": "form 右侧 radio-group 在移动端窄屏存在适配风险：label 固定 96px 后右侧空间仅约 255px，3 项以上或长文案容易溢出。cell 竖排不受此限制。",
          "allowWhen": "2 选项短文案（单条 ≤4 字）时 form 仍可用，如 UI Kit 中「统计口径」示例"
        }
      ]
    }
  ],
  "lowConfidence": false,
  "warnings": [
    "ui_kits/app/index.html 是 Showcase，含演示用手机壳和部分业务样式，不应整体复制为通用页面模板。",
    "不要把“不能复制 .uikit-shell/.phone-frame/.phone-screen”误读成“不能贴近最佳页面范式”；页面模式、section 节奏和摘要结构可以继承。",
    "凡是设置、权限、规则、配置类页面，默认优先匹配 biz-rule-config 范式，再决定是否需要补充业务差异。",
    "页面蓝图不等于最终交付形态；最终应落成真实项目工程，而不是单个静态页面文件。",
    "生产组件图标应优先使用 iconfont.css；UI Kit 中的演示图标如使用 CDN，应在真实项目中替换为库内图标体系。"
  ],
