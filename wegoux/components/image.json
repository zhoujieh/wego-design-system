  "usageHints": [
    "商品图优先使用矩形或宽幅规格，头像类场景使用 circle。",
    "contain 适合完整展示 logo、海报缩略或比例敏感资产。",
    "error 占位只做兜底提示，不替代正式空状态组件。"
  ],
  "doNotInvent": [
